{% extends "_base.html.j2" %}

{% block page_hero %}
<div class="page-hero-strip">
  <div class="page-hero-inner">
    <div class="page-hero-eyebrow">Ban the Bots · Live tracker</div>
    <h1 class="page-hero-title">AI Layoffs Tracker</h1>
    <p class="page-hero-subtitle">
      Companies that have cut jobs citing AI automation — tracked by industry, state, and date.
      {% if total %}<strong>{{ "{:,}".format(total) }} companies</strong> documented so far.{% endif %}
    </p>
  </div>
</div>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>AI Layoffs</span>
  </nav>

  {# Filters #}
  <form method="get" action="/ai-layoffs/" class="cr-search-panel" role="search" aria-label="Filter layoffs">
    <label class="cr-search-label">Filter layoffs</label>
    <div class="cr-search-row">
      <select name="industry" aria-label="Filter by industry">
        <option value="">All industries</option>
        {% for ind in industries %}
        <option value="{{ ind }}" {% if ind == industry_filter %}selected{% endif %}>
          {{ ind|replace('-', ' ')|title }}
        </option>
        {% endfor %}
      </select>
      <select name="state" aria-label="Filter by state">
        <option value="">All states</option>
        {% for st in states %}
        <option value="{{ st }}" {% if st == state_filter %}selected{% endif %}>{{ st }}</option>
        {% endfor %}
      </select>
      <select name="year" aria-label="Filter by year">
        <option value="">All years</option>
        {% for yr in years %}
        <option value="{{ yr }}" {% if yr|string == year_filter %}selected{% endif %}>{{ yr }}</option>
        {% endfor %}
      </select>
      <button type="submit">Filter</button>
      {% if industry_filter or state_filter or year_filter %}
      <a href="/ai-layoffs/" style="padding: 13px 16px; font-size:14px; color:var(--sr-gray-text);">Clear</a>
      {% endif %}
    </div>
    <p class="cr-search-help">
      {% if industry_filter or state_filter or year_filter %}
        Showing {{ total }} result{% if total != 1 %}s{% endif %}
        {% if industry_filter %} in <strong>{{ industry_filter|replace('-',' ')|title }}</strong>{% endif %}
        {% if state_filter %} in <strong>{{ state_filter }}</strong>{% endif %}
        {% if year_filter %} from <strong>{{ year_filter }}</strong>{% endif %}.
      {% else %}
        {{ total }} layoff event{% if total != 1 %}s{% endif %} documented.
        {% if total_jobs %}Affecting an estimated <strong>{{ "{:,}".format(total_jobs) }}</strong> jobs.{% endif %}
      {% endif %}
    </p>
  </form>

  {# Layoffs table #}
  {% if layoffs %}
  <div style="overflow-x:auto; margin: 8px 0 24px;">
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
      <thead>
        <tr style="border-bottom:2px solid var(--sr-blue); text-align:left;">
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Date</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Company</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Industry</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Jobs Cut</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">State</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">AI Cause</th>
        </tr>
      </thead>
      <tbody>
        {% for row in layoffs %}
        <tr style="border-bottom:1px solid var(--sr-gray-light); transition:background 0.12s;"
            onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
          <td style="padding:12px; white-space:nowrap; color:var(--sr-gray-text); font-size:13px; vertical-align:top;">
            {{ row.announced_date.strftime('%b %d, %Y') if row.announced_date else '—' }}
          </td>
          <td style="padding:12px; vertical-align:top; min-width:160px;">
            <span style="font-family:var(--font-serif); font-weight:700; font-size:15px; color:var(--sr-blue-dark); line-height:1.3; display:block;">
              {{ row.company }}
            </span>
            {% if row.source_url %}
            <a href="{{ row.source_url }}" rel="nofollow noopener" target="_blank"
               style="font-size:12px; color:var(--sr-gray-text); text-decoration:none;">
              {{ row.source_name or 'Source' }} ↗
            </a>
            {% endif %}
          </td>
          <td style="padding:12px; vertical-align:top;">
            {% if row.industry %}
            <a href="/ai-layoffs/?industry={{ row.industry }}"
               style="font-size:12px; font-weight:600; color:var(--sr-blue); text-decoration:none; white-space:nowrap;">
              {{ row.industry|replace('-',' ')|title }}
            </a>
            {% else %}
            <span style="color:var(--sr-gray-text); font-size:12px;">—</span>
            {% endif %}
          </td>
          <td style="padding:12px; vertical-align:top; text-align:right; font-weight:700; font-size:15px; color:var(--sr-red);">
            {% if row.job_count %}{{ "{:,}".format(row.job_count) }}{% else %}—{% endif %}
          </td>
          <td style="padding:12px; vertical-align:top;">
            {% if row.state %}
            <a href="/ai-layoffs/?state={{ row.state }}"
               style="font-size:12px; color:var(--sr-gray-text); text-decoration:none;">
              {{ row.state }}
            </a>
            {% else %}
            <span style="color:var(--sr-gray-text); font-size:12px;">{{ row.country or '—' }}</span>
            {% endif %}
          </td>
          <td style="padding:12px; vertical-align:top; font-size:13px; color:var(--sr-dark-text); max-width:240px; line-height:1.5;">
            {{ row.ai_cause_notes or '—' }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {# Pagination #}
  {% if total_pages > 1 %}
  <nav class="pagination" aria-label="Layoff pages">
    {% set _qs = ('&industry=' ~ industry_filter) if industry_filter else '' %}
    {% set _qs = _qs ~ (('&state=' ~ state_filter) if state_filter else '') %}
    {% set _qs = _qs ~ (('&year=' ~ year_filter) if year_filter else '') %}
    {% if page > 1 %}
      <a href="/ai-layoffs/?page={{ page - 1 }}{{ _qs }}" class="pagination-link" rel="prev">&larr; Newer</a>
    {% else %}
      <span class="pagination-link disabled">&larr; Newer</span>
    {% endif %}
    <span class="pagination-info">Page {{ page }} of {{ total_pages }}</span>
    {% if page < total_pages %}
      <a href="/ai-layoffs/?page={{ page + 1 }}{{ _qs }}" class="pagination-link" rel="next">Older &rarr;</a>
    {% else %}
      <span class="pagination-link disabled">Older &rarr;</span>
    {% endif %}
  </nav>
  {% endif %}

  {% else %}
  <div style="padding: 40px 0; color:var(--sr-gray-text);">
    <p>No layoff records found{% if industry_filter or state_filter or year_filter %} matching the selected filters{% endif %}.</p>
    {% if industry_filter or state_filter or year_filter %}
    <p style="margin-top:8px;"><a href="/ai-layoffs/">Clear filters →</a></p>
    {% endif %}
  </div>
  {% endif %}

  {# Cross-links #}
  <div style="margin: 32px 0 16px; padding: 18px 22px; background:var(--sr-gray-bg); border-left:3px solid var(--sr-blue); border-radius:3px; font-size:14px; line-height:1.7;">
    <strong>Want the full picture?</strong>
    See <a href="/fighting-back/">who's fighting back</a> against AI job displacement,
    read our <a href="/ai-proof-jobs/">AI-proof jobs guide</a>, or use the
    <a href="/will-ai-replace-my-job/">job checker tool</a> to look up your own role.
  </div>

</section>
{% endblock %}
