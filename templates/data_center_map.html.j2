{% extends "_base.html.j2" %}

{% block head_extra %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<style>
  #dc-map {
    height: 520px;
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--sr-gray-light);
    z-index: 0;
  }
  .dc-sidebar {
    background: var(--white);
    border: 1px solid var(--sr-gray-light);
    border-radius: 4px;
    padding: 20px 22px;
    font-size: 14px;
    line-height: 1.6;
    min-height: 160px;
  }
  .dc-sidebar-empty {
    color: var(--sr-gray-text);
    font-style: italic;
    padding: 16px 0;
  }
  .dc-stat-row {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin: 20px 0 28px;
  }
  .dc-stat {
    background: var(--sr-gray-bg);
    border: 1px solid var(--sr-gray-light);
    border-radius: 4px;
    padding: 14px 20px;
    text-align: center;
    flex: 1 1 140px;
  }
  .dc-stat-num {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 700;
    color: var(--sr-blue-dark);
    display: block;
  }
  .dc-stat-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--sr-gray-text);
    display: block;
    margin-top: 2px;
  }
  .dc-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin: 12px 0 20px;
    font-size: 13px;
    color: var(--sr-dark-text);
  }
  .dc-legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .dc-legend-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: inline-block;
    border: 2px solid rgba(0,0,0,0.2);
  }
  @media (max-width: 768px) {
    #dc-map { height: 360px; }
  }
</style>
{% endblock %}

{% block page_hero %}
<div class="page-hero-strip">
  <div class="page-hero-inner">
    <div class="page-hero-eyebrow">Ban the Bots · Interactive map</div>
    <h1 class="page-hero-title">Find AI Data Centers Near You</h1>
    <p class="page-hero-subtitle">
      Where AI's physical infrastructure lives — and what it costs your community
      in water, power, and land. Click any marker to learn more.
    </p>
  </div>
</div>
{% endblock %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Data Center Map</span>
  </nav>

  {# Stats strip #}
  <div class="dc-stat-row">
    <div class="dc-stat">
      <span class="dc-stat-num">{{ total }}</span>
      <span class="dc-stat-label">Facilities tracked</span>
    </div>
    <div class="dc-stat">
      <span class="dc-stat-num">{{ proposed_count }}</span>
      <span class="dc-stat-label">Proposed or under construction</span>
    </div>
    <div class="dc-stat">
      {% if total_mw %}
      <span class="dc-stat-num">{{ "{:,.0f}".format(total_mw) }} MW</span>
      {% else %}
      <span class="dc-stat-num">—</span>
      {% endif %}
      <span class="dc-stat-label">Total known capacity</span>
    </div>
  </div>

  {# Legend #}
  <div class="dc-legend">
    <span style="font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text); align-self:center;">Status:</span>
    <span class="dc-legend-item"><span class="dc-legend-dot" style="background:#2563eb;"></span> Operating</span>
    <span class="dc-legend-item"><span class="dc-legend-dot" style="background:#f59e0b;"></span> Under Construction</span>
    <span class="dc-legend-item"><span class="dc-legend-dot" style="background:#dc2626;"></span> Proposed</span>
  </div>

  {# Map + sidebar layout #}
  <div style="display:grid; grid-template-columns: 1fr 320px; gap:16px; align-items:start; margin-bottom:32px;">
    <div>
      <div id="dc-map" role="application" aria-label="Interactive map of AI data centers in the United States"></div>
    </div>
    <div>
      <div class="dc-sidebar" id="dc-sidebar">
        <p class="dc-sidebar-empty">Click a marker on the map to see details about that data center.</p>
      </div>
      <p style="font-size:12px; color:var(--sr-gray-text); margin-top:10px; line-height:1.5;">
        Data sourced from public utility filings, state permit records, and news reports.
        Capacity figures are estimates. <a href="/briefing">See our daily briefings</a> for the latest developments.
      </p>
    </div>
  </div>

  {# List view below map #}
  <h2 style="font-family:var(--font-serif); font-size:22px; color:var(--sr-blue-dark); margin:8px 0 16px;">All Tracked Facilities</h2>
  <div style="overflow-x:auto; margin-bottom:32px;">
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
      <thead>
        <tr style="border-bottom:2px solid var(--sr-blue); text-align:left;">
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Name / Operator</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Location</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Status</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Capacity</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Water Source</th>
        </tr>
      </thead>
      <tbody>
        {% set _st_colors = {'operating': '#166534', 'under_construction': '#92400e', 'proposed': '#991b1b'} %}
        {% set _st_bgs = {'operating': '#dcfce7', 'under_construction': '#fef3c7', 'proposed': '#fee2e2'} %}
        {% for dc in data_centers %}
        <tr style="border-bottom:1px solid var(--sr-gray-light); transition:background 0.12s;"
            onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
          <td style="padding:12px; vertical-align:top; min-width:200px;">
            <span style="font-weight:700; color:var(--sr-blue-dark); display:block; line-height:1.3;">{{ dc.name }}</span>
            {% if dc.operator %}
            <span style="font-size:12px; color:var(--sr-gray-text);">{{ dc.operator }}</span>
            {% endif %}
          </td>
          <td style="padding:12px; vertical-align:top; font-size:13px; color:var(--sr-dark-text);">
            {% if dc.city %}{{ dc.city }}, {% endif %}{{ dc.state or dc.country }}
            {% if dc.county %}<br><span style="font-size:12px; color:var(--sr-gray-text);">{{ dc.county }}</span>{% endif %}
          </td>
          <td style="padding:12px; vertical-align:top;">
            <span style="display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;
                         color:{{ _st_colors.get(dc.status, '#374151') }};
                         background:{{ _st_bgs.get(dc.status, '#f3f4f6') }};">
              {{ dc.status|replace('_',' ')|title }}
            </span>
          </td>
          <td style="padding:12px; vertical-align:top; font-size:13px; color:var(--sr-dark-text); white-space:nowrap;">
            {% if dc.capacity_mw %}{{ "{:,.0f}".format(dc.capacity_mw) }} MW{% else %}—{% endif %}
          </td>
          <td style="padding:12px; vertical-align:top; font-size:13px; color:var(--sr-dark-text); max-width:200px;">
            {{ dc.water_source or '—' }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {# Cross-links #}
  <div style="padding: 18px 22px; background:var(--sr-gray-bg); border-left:3px solid var(--sr-blue); border-radius:3px; font-size:14px; line-height:1.7; margin-bottom:16px;">
    <strong>Want the full story?</strong>
    Read our explainer on <a href="/explainers/data-center-impact">what AI data centers mean for your community</a>,
    track <a href="/ai-layoffs/">AI-driven layoffs</a>, or see
    <a href="/fighting-back/">who's fighting back</a>.
  </div>

</section>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLs=" crossorigin=""></script>
<script>
(function () {
  var data = {{ map_data | tojson }};

  var map = L.map('dc-map', {
    center: [38.5, -96],
    zoom: 4,
    scrollWheelZoom: false
  });

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 18,
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
  }).addTo(map);

  var statusColors = {
    'operating': '#2563eb',
    'under_construction': '#f59e0b',
    'proposed': '#dc2626'
  };

  var sidebar = document.getElementById('dc-sidebar');

  function markerColor(status) {
    return statusColors[status] || '#6b7280';
  }

  function makeCircle(dc) {
    if (dc.lat == null || dc.lng == null) return;
    var radius = dc.capacity_mw ? Math.max(8, Math.min(28, dc.capacity_mw / 80)) : 10;
    var circle = L.circleMarker([dc.lat, dc.lng], {
      radius: radius,
      fillColor: markerColor(dc.status),
      color: 'rgba(0,0,0,0.25)',
      weight: 1.5,
      fillOpacity: 0.8
    }).addTo(map);

    circle.on('click', function () {
      var mw = dc.capacity_mw ? dc.capacity_mw.toLocaleString() + ' MW' : 'Unknown';
      var status = (dc.status || '').replace(/_/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); });
      var html = '<strong style="font-family:var(--font-serif);font-size:16px;color:var(--sr-blue-dark);display:block;margin-bottom:6px;">' + dc.name + '</strong>';
      if (dc.operator) html += '<span style="font-size:13px;color:var(--sr-gray-text);display:block;margin-bottom:10px;">' + dc.operator + '</span>';
      html += '<table style="width:100%;font-size:13px;border-collapse:collapse;">';
      var rows = [
        ['Status', '<span style="font-weight:700;color:' + markerColor(dc.status) + ';">' + status + '</span>'],
        ['Location', [dc.city, dc.state].filter(Boolean).join(', ') || dc.country || '—'],
        ['County', dc.county || '—'],
        ['Capacity', mw],
        ['Water Source', dc.water_source || '—'],
      ];
      if (dc.announced_date) rows.push(['Announced', dc.announced_date]);
      rows.forEach(function(r) {
        html += '<tr><td style="padding:4px 0;color:var(--sr-gray-text);width:40%;vertical-align:top;">' + r[0] + '</td>';
        html += '<td style="padding:4px 0;color:var(--sr-dark-text);font-weight:600;">' + r[1] + '</td></tr>';
      });
      html += '</table>';
      if (dc.notes) {
        html += '<p style="margin:10px 0 0;font-size:12px;color:var(--sr-gray-text);line-height:1.55;">' + dc.notes + '</p>';
      }
      if (dc.source_url) {
        html += '<a href="' + dc.source_url + '" rel="nofollow noopener" target="_blank" style="display:inline-block;margin-top:10px;font-size:12px;color:var(--sr-blue);">Source ↗</a>';
      }
      sidebar.innerHTML = html;
    });

    circle.on('mouseover', function() { this.setStyle({ weight: 3 }); });
    circle.on('mouseout', function() { this.setStyle({ weight: 1.5 }); });
  }

  data.forEach(makeCircle);
})();
</script>

<style>
  @media (max-width: 900px) {
    /* Stack map and sidebar vertically on narrow screens */
    section .container > div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
{% endblock %}
