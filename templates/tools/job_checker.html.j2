{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .jc-hero {
    background: var(--sr-blue);
    color: var(--white);
    padding: 56px 24px 64px;
    text-align: center;
  }
  .jc-hero-inner { max-width: 640px; margin: 0 auto; }
  .jc-hero h1 { font-family: var(--font-serif); font-size: clamp(28px,4vw,44px); font-weight:700; margin: 0 0 14px; line-height:1.15; color:var(--white); }
  .jc-hero-sub { font-family:var(--font-serif); font-style:italic; font-size: clamp(15px,2vw,19px); color:rgba(255,255,255,0.82); margin:0 0 32px; line-height:1.5; }
  .jc-search-wrap { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; max-width:520px; margin:0 auto; }
  .jc-search-wrap input {
    flex:1 1 260px; min-width:0; padding:14px 18px;
    border:0; border-radius:3px;
    font-family:var(--font-sans); font-size:16px;
    color:var(--sr-dark-text);
  }
  .jc-search-wrap button {
    padding:14px 26px; background:var(--sr-red); color:var(--white);
    border:0; border-radius:3px; font-family:var(--font-sans);
    font-size:15px; font-weight:700; cursor:pointer; white-space:nowrap;
    transition:background 0.15s;
  }
  .jc-search-wrap button:hover { background:#aa0000; }
  .jc-hint { font-size:13px; color:rgba(255,255,255,0.6); margin-top:12px; }

  /* Results */
  .jc-result { display:none; max-width:720px; margin:32px auto 0; text-align:left; }
  .jc-result.visible { display:block; }
  .jc-risk-banner {
    border-radius:6px; padding:22px 26px; margin-bottom:24px;
    display:flex; align-items:flex-start; gap:18px;
  }
  .jc-risk-icon { font-size:36px; line-height:1; flex-shrink:0; }
  .jc-risk-title { font-family:var(--font-serif); font-size:22px; font-weight:700; margin:0 0 6px; }
  .jc-risk-msg { font-size:14px; line-height:1.65; margin:0; }

  .jc-section { margin-bottom:22px; }
  .jc-section h3 { font-family:var(--font-serif); font-size:17px; color:var(--sr-blue-dark); margin:0 0 10px; }
  .jc-section ul { margin:0; padding-left:20px; }
  .jc-section li { font-size:14px; line-height:1.7; color:var(--sr-dark-text); }

  .jc-skills { display:flex; flex-wrap:wrap; gap:8px; }
  .jc-skill-pill {
    background:#dbeafe; color:#1e40af;
    padding:4px 12px; border-radius:999px;
    font-size:13px; font-weight:600;
  }

  .jc-timeline { background:var(--sr-gray-bg); border-left:3px solid var(--sr-blue); padding:12px 16px; border-radius:0 4px 4px 0; font-size:14px; line-height:1.65; color:var(--sr-dark-text); }

  .jc-no-match { display:none; max-width:560px; margin:28px auto 0; text-align:center; }
  .jc-no-match.visible { display:block; }

  /* Popular examples */
  .jc-examples { margin-top:20px; }
  .jc-example-btn {
    display:inline-block; margin:4px; padding:6px 14px;
    background:rgba(255,255,255,0.12); color:rgba(255,255,255,0.85);
    border:1px solid rgba(255,255,255,0.25); border-radius:999px;
    font-size:13px; cursor:pointer; transition:background 0.12s;
  }
  .jc-example-btn:hover { background:rgba(255,255,255,0.22); }
</style>
{% endblock %}

{% block page_hero %}{% endblock %}

{% block content %}
{# Custom hero with inline search #}
<div class="jc-hero">
  <div class="jc-hero-inner">
    <div style="font-size:11px;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,0.55);margin-bottom:14px;">Ban the Bots · Job Checker</div>
    <h1>Will AI Replace My Job?</h1>
    <p class="jc-hero-sub">Type your job title to see what the research says — what's at risk, what's resilient, and what skills to build.</p>
    <div class="jc-search-wrap">
      <input type="text" id="jc-input" placeholder="e.g. teacher, nurse, truck driver…" autocomplete="off" autocorrect="off" spellcheck="false" aria-label="Enter your job title">
      <button id="jc-btn" type="button">Check my job</button>
    </div>
    <div class="jc-examples">
      <span style="font-size:12px;color:rgba(255,255,255,0.5);margin-right:6px;">Try:</span>
      <button class="jc-example-btn" data-job="Graphic Designer">Graphic Designer</button>
      <button class="jc-example-btn" data-job="Nurse">Nurse</button>
      <button class="jc-example-btn" data-job="Accountant">Accountant</button>
      <button class="jc-example-btn" data-job="Truck Driver">Truck Driver</button>
      <button class="jc-example-btn" data-job="Teacher">Teacher</button>
      <button class="jc-example-btn" data-job="Software Engineer">Software Engineer</button>
    </div>
    <p class="jc-hint" id="jc-hint" aria-live="polite"></p>
  </div>

  {# Results — rendered inside the hero section, below the search #}
  <div class="jc-result" id="jc-result" role="region" aria-live="polite" aria-label="Job risk results">
    <div class="jc-risk-banner" id="jc-banner">
      <div class="jc-risk-icon" id="jc-icon"></div>
      <div>
        <div class="jc-risk-title" id="jc-risk-title"></div>
        <p class="jc-risk-msg" id="jc-risk-msg"></p>
      </div>
    </div>

    <div style="background:rgba(255,255,255,0.06);border-radius:6px;padding:22px 24px;">
      <div class="jc-section" id="jc-sec-risk">
        <h3 style="color:rgba(255,255,255,0.9);">Tasks most at risk from AI</h3>
        <ul id="jc-at-risk"></ul>
      </div>
      <div class="jc-section" id="jc-sec-resilient">
        <h3 style="color:rgba(255,255,255,0.9);">What AI still can't do in this role</h3>
        <ul id="jc-resilient"></ul>
      </div>
      <div class="jc-section" id="jc-sec-skills" style="display:none;">
        <h3 style="color:rgba(255,255,255,0.9);">Skills that make you more resilient</h3>
        <div class="jc-skills" id="jc-skills-list"></div>
      </div>
      <div class="jc-section" id="jc-sec-timeline" style="display:none;">
        <h3 style="color:rgba(255,255,255,0.9);">What the research says</h3>
        <div class="jc-timeline" style="background:rgba(255,255,255,0.08);border-left-color:rgba(255,255,255,0.4);color:rgba(255,255,255,0.85);" id="jc-timeline"></div>
        <div style="font-size:12px;color:rgba(255,255,255,0.45);margin-top:8px;" id="jc-source"></div>
      </div>
    </div>
  </div>

  <div class="jc-no-match" id="jc-no-match">
    <p style="color:rgba(255,255,255,0.8);font-size:15px;line-height:1.65;">
      We don't have data for that specific title yet. In general: <strong>jobs requiring physical presence, human judgment, care, or trust</strong> are more resilient. <strong>Routine data processing, document work, and pattern-matching</strong> are most at risk.
    </p>
    <p style="margin-top:12px;">
      <a href="/explainers/ai-proof-jobs" style="color:rgba(255,255,255,0.75);font-size:14px;">Read our full AI-proof jobs guide →</a>
    </p>
  </div>
</div>

{# Below-fold: context and cross-links #}
<section class="container" style="padding-top:40px;">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Will AI Replace My Job?</span>
  </nav>

  <div style="max-width:720px; margin: 24px 0 40px;">
    <h2 style="font-family:var(--font-serif);font-size:24px;color:var(--sr-blue-dark);margin:0 0 14px;">How to read these results</h2>
    <p style="font-size:15px;line-height:1.75;color:var(--sr-dark-text);">
      This tool is based on automation research from the BLS, McKinsey Global Institute, Goldman Sachs, Oxford Economics, and the World Economic Forum. Risk levels reflect the <em>current and near-term</em> (5–10 year) outlook — not science fiction.
    </p>
    <p style="font-size:15px;line-height:1.75;color:var(--sr-dark-text);margin-top:12px;">
      "High risk" doesn't mean your job disappears next year. It means a significant portion of the tasks in that role can already be done by AI systems, and that trend is accelerating. "Low risk" means the core of the work requires human presence, judgment, relationships, or physical dexterity that AI cannot replicate today.
    </p>
  </div>

  {# Three cross-link cards #}
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;margin-bottom:48px;">
    <a href="/explainers/ai-proof-jobs" style="text-decoration:none;border:1px solid var(--sr-gray-light);border-radius:6px;padding:20px;display:block;background:var(--white);">
      <div style="font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--sr-red);font-weight:700;margin-bottom:8px;">Guide</div>
      <div style="font-family:var(--font-serif);font-size:17px;color:var(--sr-blue-dark);font-weight:700;line-height:1.3;margin-bottom:8px;">The Most AI-Proof Jobs</div>
      <div style="font-size:13px;color:var(--sr-gray-text);line-height:1.55;">Deep dive into which careers are genuinely resilient and why.</div>
    </a>
    <a href="/ai-layoffs/" style="text-decoration:none;border:1px solid var(--sr-gray-light);border-radius:6px;padding:20px;display:block;background:var(--white);">
      <div style="font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--sr-red);font-weight:700;margin-bottom:8px;">Tracker</div>
      <div style="font-family:var(--font-serif);font-size:17px;color:var(--sr-blue-dark);font-weight:700;line-height:1.3;margin-bottom:8px;">AI Layoffs Tracker</div>
      <div style="font-size:13px;color:var(--sr-gray-text);line-height:1.55;">Companies that have cut jobs due to AI — searchable by industry.</div>
    </a>
    <a href="/fighting-back/" style="text-decoration:none;border:1px solid var(--sr-gray-light);border-radius:6px;padding:20px;display:block;background:var(--white);">
      <div style="font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--sr-red);font-weight:700;margin-bottom:8px;">Tracker</div>
      <div style="font-family:var(--font-serif);font-size:17px;color:var(--sr-blue-dark);font-weight:700;line-height:1.3;margin-bottom:8px;">Who's Fighting Back</div>
      <div style="font-size:13px;color:var(--sr-gray-text);line-height:1.55;">Unions, companies, and governments protecting workers from AI displacement.</div>
    </a>
  </div>

</section>

<script>
(function () {
  var DATA = {{ job_data | tojson }};
  var CATEGORIES = DATA.categories;
  var JOBS = DATA.jobs;

  var input = document.getElementById('jc-input');
  var btn = document.getElementById('jc-btn');
  var hint = document.getElementById('jc-hint');
  var resultEl = document.getElementById('jc-result');
  var noMatchEl = document.getElementById('jc-no-match');

  var icons = { high: '⚠️', medium: '📊', low: '✅' };

  function normalize(s) {
    return (s || '').toLowerCase().replace(/[^a-z0-9 ]/g, '').trim();
  }

  function findJob(query) {
    var q = normalize(query);
    if (!q) return null;
    for (var i = 0; i < JOBS.length; i++) {
      var job = JOBS[i];
      if (normalize(job.title) === q) return job;
      var aliases = job.aliases || [];
      for (var j = 0; j < aliases.length; j++) {
        if (normalize(aliases[j]) === q) return job;
      }
    }
    // partial match on title
    for (var i = 0; i < JOBS.length; i++) {
      var job = JOBS[i];
      if (normalize(job.title).indexOf(q) !== -1 || q.indexOf(normalize(job.title)) !== -1) return job;
      var aliases = job.aliases || [];
      for (var j = 0; j < aliases.length; j++) {
        if (normalize(aliases[j]).indexOf(q) !== -1) return job;
      }
    }
    return null;
  }

  function renderList(elId, items) {
    var el = document.getElementById(elId);
    el.innerHTML = '';
    (items || []).forEach(function(item) {
      var li = document.createElement('li');
      li.style.cssText = 'font-size:14px;line-height:1.7;color:rgba(255,255,255,0.85);';
      li.textContent = item;
      el.appendChild(li);
    });
  }

  function showResult(job) {
    var cat = CATEGORIES[job.risk] || CATEGORIES['medium'];

    document.getElementById('jc-icon').textContent = icons[job.risk] || '📊';
    document.getElementById('jc-risk-title').textContent = job.title + ' — ' + cat.label;
    document.getElementById('jc-risk-title').style.color = cat.color;
    document.getElementById('jc-risk-msg').textContent = cat.message;
    document.getElementById('jc-risk-msg').style.color = 'rgba(255,255,255,0.82)';

    var banner = document.getElementById('jc-banner');
    banner.style.background = 'rgba(255,255,255,0.08)';
    banner.style.borderLeft = '4px solid ' + cat.color;

    renderList('jc-at-risk', job.at_risk_tasks);
    renderList('jc-resilient', job.resilient_tasks);

    var skillsSec = document.getElementById('jc-sec-skills');
    var skillsList = document.getElementById('jc-skills-list');
    skillsList.innerHTML = '';
    if (job.resilient_skills && job.resilient_skills.length) {
      skillsSec.style.display = '';
      job.resilient_skills.forEach(function(s) {
        var span = document.createElement('span');
        span.className = 'jc-skill-pill';
        span.style.cssText = 'background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.9);';
        span.textContent = s;
        skillsList.appendChild(span);
      });
    } else {
      skillsSec.style.display = 'none';
    }

    var timelineSec = document.getElementById('jc-sec-timeline');
    if (job.timeline) {
      timelineSec.style.display = '';
      document.getElementById('jc-timeline').textContent = job.timeline;
      document.getElementById('jc-source').textContent = job.source ? 'Source: ' + job.source : '';
    } else {
      timelineSec.style.display = 'none';
    }

    resultEl.classList.add('visible');
    noMatchEl.classList.remove('visible');
    hint.textContent = '';
  }

  function showNoMatch(query) {
    resultEl.classList.remove('visible');
    noMatchEl.classList.add('visible');
    hint.textContent = 'No exact match for "' + query + '" — showing general guidance.';
  }

  function run() {
    var query = (input.value || '').trim();
    if (!query) { hint.textContent = 'Enter a job title above.'; return; }
    var job = findJob(query);
    if (job) {
      showResult(job);
    } else {
      showNoMatch(query);
    }
    resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  btn.addEventListener('click', run);
  input.addEventListener('keydown', function(e) { if (e.key === 'Enter') run(); });

  document.querySelectorAll('.jc-example-btn').forEach(function(b) {
    b.addEventListener('click', function() {
      input.value = b.getAttribute('data-job');
      run();
    });
  });
})();
</script>
{% endblock %}
