{% extends "_base.html.j2" %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Responsible AI</span>
  </nav>

  <header style="margin: 16px 0 32px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Ban the Bots · Industry guides
    </div>
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--sr-blue-dark); margin:8px 0 12px;">
      Responsible AI by Industry
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:18px; max-width:680px;">
      Every industry faces different AI risks. Select your sector for a plain-English breakdown
      of applicable regulations, real incidents, and a responsible adoption framework you can
      actually use.
    </p>
  </header>

  {% set _industries = industries if industries else [
    {"slug": "healthcare",     "label": "Healthcare & Medical",        "summary": "HIPAA, AI diagnostic tools, clinical liability, and patient safety risks."},
    {"slug": "finance",        "label": "Financial Services",          "summary": "CFPB guidance, algorithmic lending, fraud detection, and fair-lending compliance."},
    {"slug": "legal",          "label": "Legal & Compliance",          "summary": "AI-generated filings, hallucinated citations, attorney liability, and privilege risks."},
    {"slug": "retail",         "label": "Retail & E-commerce",         "summary": "AI-generated product copy, pricing algorithms, customer service bots, and FTC rules."},
    {"slug": "education",      "label": "Education & EdTech",          "summary": "FERPA, AI tutors, academic integrity, and the student data privacy landscape."},
    {"slug": "manufacturing",  "label": "Manufacturing & Operations",  "summary": "Automation risk, AI-driven quality control failures, and workforce displacement."},
    {"slug": "real-estate",    "label": "Real Estate & PropTech",      "summary": "Fair Housing Act and AI valuation tools, algorithmic discrimination, and disclosure rules."},
    {"slug": "marketing",      "label": "Marketing & Advertising",     "summary": "AI-generated content, FTC disclosure rules, 'AI slop' brand risk, and deepfake liability."}
  ] %}

  <div class="index-grid">
    {% for industry in _industries %}
    <article class="index-card">
      <a class="card-link" href="/responsible-ai/{{ industry.slug }}/" aria-label="{{ industry.label }}"></a>
      <div class="meta" style="text-transform:uppercase; letter-spacing:0.8px; color:#cc0000; font-weight:700; font-size:11px;">
        Industry guide
        {% if industry.briefing_count is defined and industry.briefing_count %}
        · {{ industry.briefing_count }} briefings
        {% endif %}
      </div>
      <a class="title-link" href="/responsible-ai/{{ industry.slug }}/">{{ industry.label }}</a>
      {% if industry.summary %}
      <p class="summary">{{ industry.summary }}</p>
      {% endif %}
      <p style="font-size:13px; color:var(--sr-blue); font-weight:600; margin-top:4px;">Read guide →</p>
    </article>
    {% endfor %}
  </div>

  <div style="margin: 40px 0 16px; padding: 20px 24px; background:var(--sr-gray-bg); border-left:3px solid var(--sr-blue); border-radius:3px;">
    <p style="margin:0; font-size:15px; color:var(--sr-dark-text);">
      Not sure where your business sits?
      <a href="/ai-risk-assessment/" style="font-weight:600;">Take the AI risk assessment →</a>
      Get a plain-English breakdown of where you're exposed based on your industry and current AI usage.
    </p>
  </div>

</section>
{% endblock %}
