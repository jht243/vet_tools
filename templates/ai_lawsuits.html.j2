{% extends "_base.html.j2" %}

{% block page_hero %}
<div class="page-hero-strip">
  <div class="page-hero-inner">
    <div class="page-hero-eyebrow">Ban the Bots · Live tracker</div>
    <h1 class="page-hero-title">AI Lawsuits Tracker</h1>
    <p class="page-hero-subtitle">
      Artists, writers, journalists, and institutions suing AI companies for copyright theft,
      privacy violations, and harm. {% if total %}<strong>{{ total }} cases</strong> and counting.{% endif %}
    </p>
  </div>
</div>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>AI Lawsuits</span>
  </nav>

  {# Filters #}
  <form method="get" action="/ai-lawsuits/" class="cr-search-panel" role="search" aria-label="Filter lawsuits">
    <label class="cr-search-label">Filter cases</label>
    <div class="cr-search-row">
      <select name="claim_type" aria-label="Filter by claim type">
        <option value="">All claim types</option>
        {% for ct in claim_types %}
        <option value="{{ ct }}" {% if ct == claim_type_filter %}selected{% endif %}>
          {{ ct|replace('-',' ')|title }}
        </option>
        {% endfor %}
      </select>
      <select name="defendant" aria-label="Filter by AI company">
        <option value="">All defendants</option>
        {% for d in defendants %}
        <option value="{{ d }}" {% if d == defendant_filter %}selected{% endif %}>{{ d }}</option>
        {% endfor %}
      </select>
      <select name="status" aria-label="Filter by case status">
        <option value="">All statuses</option>
        {% for s in statuses %}
        <option value="{{ s }}" {% if s == status_filter %}selected{% endif %}>{{ s|title }}</option>
        {% endfor %}
      </select>
      <button type="submit">Filter</button>
      {% if claim_type_filter or defendant_filter or status_filter %}
      <a href="/ai-lawsuits/" style="padding: 13px 16px; font-size:14px; color:var(--sr-gray-text);">Clear</a>
      {% endif %}
    </div>
    <p class="cr-search-help">
      {% if claim_type_filter or defendant_filter or status_filter %}
        Showing {{ total }} case{% if total != 1 %}s{% endif %}
        {% if claim_type_filter %} of type <strong>{{ claim_type_filter }}</strong>{% endif %}
        {% if defendant_filter %} against <strong>{{ defendant_filter }}</strong>{% endif %}
        {% if status_filter %} with status <strong>{{ status_filter }}</strong>{% endif %}.
      {% else %}
        {{ total }} legal case{% if total != 1 %}s{% endif %} in the database.
      {% endif %}
    </p>
  </form>

  {% set _status_colors = {
    'ongoing': '#1e40af',
    'filed': '#6b21a8',
    'settled': '#065f46',
    'dismissed': '#374151',
    'won': '#166534'
  } %}
  {% set _status_bgs = {
    'ongoing': '#dbeafe',
    'filed': '#f3e8ff',
    'settled': '#d1fae5',
    'dismissed': '#f3f4f6',
    'won': '#dcfce7'
  } %}

  {# Lawsuits table #}
  {% if lawsuits %}
  <div style="overflow-x:auto; margin: 8px 0 24px;">
    <table style="width:100%; border-collapse:collapse; font-size:14px;">
      <thead>
        <tr style="border-bottom:2px solid var(--sr-blue); text-align:left;">
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Filed</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Case</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Defendant</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Type</th>
          <th style="padding:10px 12px; font-family:var(--font-sans); font-size:12px; text-transform:uppercase; letter-spacing:1px; color:var(--sr-gray-text);">Status</th>
        </tr>
      </thead>
      <tbody>
        {% for case in lawsuits %}
        <tr style="border-bottom:1px solid var(--sr-gray-light); transition:background 0.12s;"
            onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background=''">
          <td style="padding:12px; white-space:nowrap; color:var(--sr-gray-text); font-size:13px; vertical-align:top;">
            {{ case.filed_date.strftime('%b %Y') if case.filed_date else '—' }}
          </td>
          <td style="padding:12px; vertical-align:top; min-width:240px;">
            <span style="font-family:var(--font-serif); font-weight:700; font-size:15px; color:var(--sr-blue-dark); line-height:1.3; display:block;">
              {{ case.case_name }}
            </span>
            <span style="font-size:13px; color:var(--sr-gray-text); display:block; margin:3px 0 5px;">
              {{ case.plaintiff }}
            </span>
            {% if case.description %}
            <span style="font-size:13px; color:var(--sr-dark-text); line-height:1.55; display:block; max-width:420px;">
              {{ case.description[:220] }}{% if case.description|length > 220 %}…{% endif %}
            </span>
            {% endif %}
            {% if case.source_url %}
            <a href="{{ case.source_url }}" rel="nofollow noopener" target="_blank"
               style="font-size:12px; color:var(--sr-gray-text); text-decoration:none; margin-top:4px; display:inline-block;">
              Source ↗
            </a>
            {% endif %}
          </td>
          <td style="padding:12px; vertical-align:top; font-size:13px; color:var(--sr-dark-text); max-width:160px;">
            <a href="/ai-lawsuits/?defendant={{ case.defendant | urlencode }}"
               style="color:var(--sr-blue); font-weight:600; text-decoration:none; font-size:13px;">
              {{ case.defendant }}
            </a>
          </td>
          <td style="padding:12px; vertical-align:top;">
            {% if case.claim_type %}
            <a href="/ai-lawsuits/?claim_type={{ case.claim_type }}"
               style="font-size:12px; font-weight:600; color:var(--sr-blue); text-decoration:none; white-space:nowrap;">
              {{ case.claim_type|replace('-',' ')|title }}
            </a>
            {% else %}
            <span style="color:var(--sr-gray-text); font-size:12px;">—</span>
            {% endif %}
          </td>
          <td style="padding:12px; vertical-align:top;">
            <span style="display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;
                         color:{{ _status_colors.get(case.status, '#374151') }};
                         background:{{ _status_bgs.get(case.status, '#f3f4f6') }};">
              {{ case.status }}
            </span>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {# Pagination #}
  {% if total_pages > 1 %}
  <nav class="pagination" aria-label="Lawsuit pages">
    {% set _qs = ('&claim_type=' ~ claim_type_filter) if claim_type_filter else '' %}
    {% set _qs = _qs ~ (('&defendant=' ~ defendant_filter) if defendant_filter else '') %}
    {% set _qs = _qs ~ (('&status=' ~ status_filter) if status_filter else '') %}
    {% if page > 1 %}
      <a href="/ai-lawsuits/?page={{ page - 1 }}{{ _qs }}" class="pagination-link" rel="prev">&larr; Newer</a>
    {% else %}
      <span class="pagination-link disabled">&larr; Newer</span>
    {% endif %}
    <span class="pagination-info">Page {{ page }} of {{ total_pages }}</span>
    {% if page < total_pages %}
      <a href="/ai-lawsuits/?page={{ page + 1 }}{{ _qs }}" class="pagination-link" rel="next">Older &rarr;</a>
    {% else %}
      <span class="pagination-link disabled">Older &rarr;</span>
    {% endif %}
  </nav>
  {% endif %}

  {% else %}
  <div style="padding: 40px 0; color:var(--sr-gray-text);">
    <p>No cases found{% if claim_type_filter or defendant_filter or status_filter %} matching the selected filters{% endif %}.</p>
    {% if claim_type_filter or defendant_filter or status_filter %}
    <p style="margin-top:8px;"><a href="/ai-lawsuits/">Clear filters →</a></p>
    {% endif %}
  </div>
  {% endif %}

  {# Cross-links #}
  <div style="margin: 32px 0 16px; padding: 18px 22px; background:var(--sr-gray-bg); border-left:3px solid var(--sr-blue); border-radius:3px; font-size:14px; line-height:1.7;">
    <strong>More on the AI backlash:</strong>
    See <a href="/fighting-back/">organizations fighting back</a> against AI,
    track <a href="/ai-layoffs/">AI-driven layoffs</a>, or read the
    <a href="/ai-backlash/">full AI backlash explainer</a>.
  </div>

</section>
{% endblock %}
