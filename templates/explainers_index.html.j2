{% extends "_base.html.j2" %}
{% block title %}{{ seo.title }}{% endblock %}
{% block meta_description %}{{ seo.description }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endblock %}
{% block og_tags %}
<meta property="og:title" content="{{ seo.title | e }}">
<meta property="og:description" content="{{ seo.description | e }}">
<meta property="og:url" content="{{ seo.canonical }}">
{% endblock %}

{% block content %}
<section class="hero" style="padding:2.5rem 0 2rem;">
  <div class="container">
    <h1>VA &amp; Military Benefits Explainers</h1>
    <p>Plain-English guides to the most confusing parts of VA claims, military retirement, and veteran healthcare.</p>
  </div>
</section>

<main class="container" style="max-width:1000px;margin:2rem auto;padding:0 1.25rem;">

  {% if pages %}
  <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr));">
    {% for page in pages %}
    <a href="/explainers/{{ page.slug }}/" class="cluster-card" style="text-decoration:none;color:inherit;">
      <h2 style="font-size:1rem;color:var(--sr-blue);margin-bottom:0.3rem;">{{ page.title }}</h2>
      {% if page.subtitle %}
      <p style="font-size:0.875rem;color:var(--sr-gray-text);">{{ page.subtitle }}</p>
      {% endif %}
    </a>
    {% endfor %}
  </div>
  {% else %}
  <!-- Static fallback list when DB not yet seeded -->
  <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr));">
    {% set explainer_list = [
      ("what-is-a-nexus-letter", "What Is a Nexus Letter?", "Why it's the key to service connection"),
      ("va-disability-rating-explained", "VA Disability Rating Explained", "How the combined rating formula works"),
      ("pact-act-explained", "PACT Act Explained", "What burn-pit veterans need to know"),
      ("cdr-explained", "Combined Disability Rating Formula", "Why 50% + 50% ≠ 100%"),
      ("tdiu-explained", "TDIU Explained", "Total Disability Individual Unemployability"),
      ("va-appeals-process", "VA Appeals Process", "BVA, CAVC, and your options"),
      ("blended-retirement-system", "Blended Retirement System", "BRS vs. legacy High-3"),
      ("bah-explained", "BAH Explained", "How Basic Allowance for Housing is calculated"),
      ("tricare-options-explained", "TRICARE Options Explained", "Prime, Select, and For Life"),
      ("government-shutdown-veterans", "Government Shutdowns & Veterans", "What stops and what continues"),
    ] %}
    {% for slug, title, desc in explainer_list %}
    <a href="/explainers/{{ slug }}/" class="cluster-card" style="text-decoration:none;color:inherit;">
      <h2 style="font-size:1rem;color:var(--sr-blue);margin-bottom:0.3rem;">{{ title }}</h2>
      <p style="font-size:0.875rem;color:var(--sr-gray-text);">{{ desc }}</p>
    </a>
    {% endfor %}
  </div>
  {% endif %}

</main>
{% endblock %}
