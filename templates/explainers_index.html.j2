{% extends "_base.html.j2" %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Explainers</span>
  </nav>

  <header style="margin: 16px 0 24px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Evergreen guides
    </div>
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--sr-blue-dark); margin:8px 0 12px;">
      AI Explainers for Business Owners
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:18px;">
      Plain-English answers to the questions business owners most often ask
      about AI regulation, liability, labor disruption, and how to make
      defensible decisions when adopting AI tools.
    </p>
  </header>

  <div class="cr-search-panel" role="search" aria-label="Search explainers">
    <label class="cr-search-label" for="explainer-search">Search explainers</label>
    <div class="cr-search-row">
      <input type="search" id="explainer-search" placeholder="Search EU AI Act, NIST, liability, responsible AI…" autocomplete="off">
    </div>
  </div>

  <div class="cr-empty-filter" id="explainer-empty">No explainers match that search.</div>

  <div class="index-grid">
    {% for e in explainers %}
    <article class="index-card" data-search="{{ (e.title ~ ' ' ~ (e.summary or '') ~ ' ' ~ (e.subtitle or ''))|lower }}">
      <a class="title-link" href="{{ e.canonical_path }}">{{ e.title }}</a>
      <div class="meta">{{ e.word_count or '—' }} words · Updated {{ e.last_generated_at.strftime('%b %d, %Y') if e.last_generated_at else '' }}</div>
      <p class="summary">{{ e.summary or e.subtitle or '' }}</p>
    </article>
    {% else %}
    <p style="color: var(--sr-gray-text);">No explainers published yet.</p>
    {% endfor %}
  </div>

</section>

<script>
(function () {
  var input = document.getElementById('explainer-search');
  var empty = document.getElementById('explainer-empty');
  if (!input) return;
  var cards = Array.prototype.slice.call(document.querySelectorAll('.index-card[data-search]'));
  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    var visible = 0;
    cards.forEach(function (card) {
      var show = !q || (card.getAttribute('data-search') || '').indexOf(q) !== -1;
      card.style.display = show ? '' : 'none';
      if (show) visible += 1;
    });
    if (empty) empty.style.display = q && visible === 0 ? 'block' : 'none';
  });
})();
</script>
{% endblock %}
