{% extends "_base.html.j2" %}
{% block title %}{{ seo.title }}{% endblock %}
{% block meta_description %}{{ seo.description }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endblock %}
{% block og_tags %}
<meta property="og:title" content="{{ seo.title | e }}">
<meta property="og:description" content="{{ seo.description | e }}">
<meta property="og:url" content="{{ seo.canonical }}">
<meta property="og:type" content="website">
{% endblock %}

{% block content %}
<section class="hero" style="padding:2.5rem 0 2rem;">
  <div class="container">
    <h1>Free VA &amp; Military Benefits Tools</h1>
    <p>Calculators and guides to help you understand your VA disability rating, military retirement pay, and BAH — no signup required.</p>
  </div>
</section>

<main class="container" style="max-width:1000px;margin:2rem auto;padding:0 1.25rem;">

  <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(260px,1fr));">
    {% for tool in tools %}
    <a href="/tools/{{ tool.slug }}/" class="cluster-card" style="text-decoration:none;color:inherit;">
      <span class="tool-icon">{{ tool.icon }}</span>
      <h2 style="font-size:1rem;margin-bottom:0.3rem;">{{ tool.title }}</h2>
      <p>{{ tool.description }}</p>
      <span class="status-pill {% if tool.live %}status-pill--live{% endif %}">
        {{ 'Live' if tool.live else 'Coming soon' }}
      </span>
    </a>
    {% endfor %}
  </div>

  <div class="page-disclaimer" style="margin-top:2.5rem;">
    <strong>Note:</strong> These tools provide estimates only. Actual VA ratings, retirement pay, and
    allowances are determined by the VA and DoD. Always confirm results with official sources.
  </div>

</main>
{% endblock %}
