const LOCATIONS = Object.keys(BAH_DATA).sort();
const BAR_COLORS = ['var(--sr-blue)', 'var(--sr-red)', '#2e7d32'];

function fmt(n) { return '$' + n.toLocaleString('en-US'); }

function populateLocations() {
  ['cmp-loc1','cmp-loc2','cmp-loc3'].forEach(function(id, idx) {
    var sel = document.getElementById(id);
    if (idx === 2) {
      var none = document.createElement('option');
      none.value = '';
      none.textContent = 'None (skip)';
      sel.appendChild(none);
    }
    LOCATIONS.forEach(function(loc, li) {
      var opt = document.createElement('option');
      opt.value = loc;
      opt.textContent = loc;
      if (idx === 0 && li === LOCATIONS.indexOf('San Diego, CA')) opt.selected = true;
      if (idx === 1 && li === LOCATIONS.indexOf('Fort Liberty, NC')) opt.selected = true;
      sel.appendChild(opt);
    });
  });
}

function compareBah() {
  var grade = document.getElementById('cmp-grade').value;
  var dep = document.querySelector('input[name="cmp-dep"]:checked').value;
  var locs = [];
  var loc1 = document.getElementById('cmp-loc1').value;
  var loc2 = document.getElementById('cmp-loc2').value;
  var loc3 = document.getElementById('cmp-loc3').value;

  if (loc1) locs.push(loc1);
  if (loc2) locs.push(loc2);
  if (loc3) locs.push(loc3);

  if (locs.length < 2) {
    alert('Please select at least two locations to compare.');
    return;
  }

  var rates = [];
  for (var i = 0; i < locs.length; i++) {
    var locData = BAH_DATA[locs[i]];
    if (!locData || !locData[grade]) {
      alert('Data not available for ' + locs[i] + ' at grade ' + grade + '.');
      return;
    }
    var monthly = dep === 'with' ? locData[grade].with : locData[grade].no;
    rates.push({ loc: locs[i], monthly: monthly, annual: monthly * 12 });
  }

  var baseRate = rates[0].monthly;

  /* Build table */
  var tbody = document.getElementById('cmp-table-body');
  tbody.innerHTML = '';
  for (var j = 0; j < rates.length; j++) {
    var r = rates[j];
    var diff = r.monthly - baseRate;
    var diffPct = baseRate > 0 ? ((diff / baseRate) * 100) : 0;
    var diffStr = j === 0 ? '—' : (diff >= 0 ? '+' : '') + fmt(diff) + ' (' + (diff >= 0 ? '+' : '') + diffPct.toFixed(1) + '%)';
    var diffColor = j === 0 ? 'var(--sr-dark-text)' : (diff > 0 ? '#2e7d32' : (diff < 0 ? 'var(--sr-red)' : 'var(--sr-dark-text)'));

    var tr = document.createElement('tr');
    tr.style.background = j % 2 === 0 ? '#fff' : 'var(--sr-gray-bg)';
    tr.innerHTML =
      '<td style="padding:0.55rem 0.75rem;border-bottom:1px solid var(--sr-gray-light);font-weight:600;">' + r.loc + '</td>' +
      '<td style="padding:0.55rem 0.75rem;text-align:right;border-bottom:1px solid var(--sr-gray-light);">' + fmt(r.monthly) + '/mo</td>' +
      '<td style="padding:0.55rem 0.75rem;text-align:right;border-bottom:1px solid var(--sr-gray-light);">' + fmt(r.annual) + '/yr</td>' +
      '<td style="padding:0.55rem 0.75rem;text-align:right;border-bottom:1px solid var(--sr-gray-light);color:' + diffColor + ';font-weight:600;">' + diffStr + '</td>';
    tbody.appendChild(tr);
  }

  /* Build bar chart */
  var chart = document.getElementById('cmp-chart');
  chart.innerHTML = '';
  var maxRate = Math.max.apply(null, rates.map(function(x) { return x.monthly; }));

  for (var k = 0; k < rates.length; k++) {
    var pct = maxRate > 0 ? (rates[k].monthly / maxRate * 100) : 0;
    var barRow = document.createElement('div');
    barRow.style.cssText = 'display:flex;align-items:center;gap:0.75rem;';
    barRow.innerHTML =
      '<div style="min-width:180px;font-size:0.85rem;font-weight:600;color:var(--sr-dark-text);text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="' + rates[k].loc + '">' + rates[k].loc + '</div>' +
      '<div style="flex:1;background:var(--sr-gray-light);border-radius:4px;height:28px;position:relative;">' +
        '<div style="width:' + pct + '%;height:100%;background:' + BAR_COLORS[k] + ';border-radius:4px;transition:width 0.4s ease;"></div>' +
      '</div>' +
      '<div style="min-width:80px;font-size:0.85rem;font-weight:700;color:var(--sr-dark-text);">' + fmt(rates[k].monthly) + '</div>';
    chart.appendChild(barRow);
  }

  document.getElementById('cmp-results').style.display = 'block';
  document.getElementById('cmp-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

populateLocations();
</script>
