{% extends "_base.html.j2" %}
{% from "_recent_briefings.html.j2" import recent_briefings_rail %}

{% block title %}VA Claims Workspace — Free VA & Military Benefits Tools{% endblock %}

{% block extra_head %}
{% if jsonld %}
<script type="application/ld+json">{{ jsonld | tojson }}</script>
{% endif %}
{% endblock %}

{% block content %}

<!-- Hero -->
<section class="hero" aria-label="Hero">
  <div class="container">
    <h1>Understand Your VA Benefits &mdash; Free Tools &amp; Daily Briefings</h1>
    <p>We track VA policy, calculate your disability rating, and explain military benefits in plain English.</p>
    <div class="hero-cta">
      <a href="/tools/va-disability-rating-calculator/" class="btn btn--primary">Calculate Your Rating</a>
      <a href="/briefing/" class="btn btn--outline">Browse Today's Briefings</a>
    </div>
  </div>
</section>

<!-- Stats strip -->
<div class="stats-strip" aria-label="Site statistics">
  <div class="container">
    <div class="stats-strip-inner">
      <div class="stat-item">
        <span class="stat-number">{{ briefing_count | default('500+') }}</span>
        <span class="stat-label">briefings published</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">35</span>
        <span class="stat-label">conditions tracked</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">50</span>
        <span class="stat-label">state guides</span>
      </div>
    </div>
  </div>
</div>

<!-- Top Tools -->
<div class="page-wrapper">
  <div class="container">

    <section aria-label="Top calculators" style="margin-bottom:3rem;">
      <h2 class="section-heading">Free VA &amp; Military Calculators</h2>
      <div class="card-grid">

        <article class="card">
          <span class="tool-icon" aria-hidden="true">🎖️</span>
          <h3>VA Disability Rating Calculator</h3>
          <p>Estimate your combined VA disability rating using the official VA math formula — add multiple conditions.</p>
          <a href="/tools/va-disability-rating-calculator/" class="card-link">Launch Tool &rarr;</a>
        </article>

        <article class="card">
          <span class="tool-icon" aria-hidden="true">💰</span>
          <h3>Military Retirement Calculator</h3>
          <p>Estimate your monthly military retirement pay under the Legacy, BRS, or REDUX retirement systems.</p>
          <a href="/tools/military-retirement-calculator/" class="card-link">Launch Tool &rarr;</a>
        </article>

        <article class="card">
          <span class="tool-icon" aria-hidden="true">🏠</span>
          <h3>BAH Calculator</h3>
          <p>Look up your Basic Allowance for Housing rate by zip code, rank, and dependency status.</p>
          <a href="/tools/bah-calculator/" class="card-link">Launch Tool &rarr;</a>
        </article>

      </div>
      <a href="/tools/" class="view-all-link">See all 7 calculators &rarr;</a>
    </section>

    <!-- Recent briefings rail -->
    {{ recent_briefings_rail(recent_briefings, "Today's VA &amp; Military Briefings") }}

    <!-- Content clusters -->
    <section class="content-clusters" aria-label="Topic areas">
      <h2 class="section-heading">Explore by Topic</h2>
      <div class="card-grid">

        <article class="cluster-card">
          <h3><a href="/va-claims/" style="text-decoration:none;color:inherit;">VA Claims</a></h3>
          <p>How to file a VA claim, gather evidence, appeal a denial, and navigate the ratings process.</p>
          <a href="/va-claims/" class="card-link">Explore VA Claims &rarr;</a>
        </article>

        <article class="cluster-card">
          <h3><a href="/va-disability-ratings/" style="text-decoration:none;color:inherit;">VA Disability Ratings</a></h3>
          <p>Condition-by-condition rating criteria, combined ratings math, and TDIU eligibility.</p>
          <a href="/va-disability-ratings/" class="card-link">Explore Ratings &rarr;</a>
        </article>

        <article class="cluster-card">
          <h3><a href="/military-retirement/" style="text-decoration:none;color:inherit;">Military Retirement</a></h3>
          <p>Retirement system comparisons, SBP elections, CRSC vs CRDP, and pay tables.</p>
          <a href="/military-retirement/" class="card-link">Explore Retirement &rarr;</a>
        </article>

        <article class="cluster-card">
          <h3><a href="/state-benefits/" style="text-decoration:none;color:inherit;">State Benefits</a></h3>
          <p>Property tax exemptions, tuition waivers, and other state-level veterans benefits — all 50 states.</p>
          <a href="/state-benefits/" class="card-link">Explore State Benefits &rarr;</a>
        </article>

      </div>
    </section>

  </div>
</div>

<!-- Footer disclaimer -->
<div style="background:var(--sr-gray-bg);border-top:1px solid var(--sr-gray-light);padding:1.25rem 0;">
  <div class="container--narrow">
    <p style="font-size:0.82rem;color:var(--sr-gray-text);text-align:center;margin:0;">
      VA Claims Workspace provides informational content about veterans benefits and military compensation. We are not affiliated with the U.S. Department of Veterans Affairs.
    </p>
  </div>
</div>

{% endblock %}
