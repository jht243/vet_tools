{% extends "_base.html.j2" %}
{% from "_recent_briefings.html.j2" import recent_briefings_rail %}

{% block title %}Rank and Pay — Military Pay, VA Benefits &amp; Retirement Guides{% endblock %}

{% block extra_head %}
{% if jsonld %}
<script type="application/ld+json">{{ jsonld | tojson }}</script>
{% endif %}
{% endblock %}

{% block content %}

<!-- Hero -->
<section class="hero" aria-label="Hero">
  <div class="container">
    <h1>Military Pay, VA Benefits<br>&amp; Retirement</h1>
    <p>Free tools and daily briefings on BAH rates, pay tables,<br>VA claims, and retirement — in plain English.</p>
    <div class="hero-cta">
      <a href="/tools/" class="btn btn--primary">Explore Free Tools</a>
      <a href="/briefing/" class="btn btn--outline">Today's Briefings</a>
    </div>
  </div>
</section>

<!-- Stats strip -->
<div class="stats-strip" aria-label="Site statistics">
  <div class="container">
    <div class="stats-strip-inner">
      <div class="stat-item">
        <span class="stat-number">{{ briefing_count | default('500+') }}</span>
        <span class="stat-label">briefings published</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">35</span>
        <span class="stat-label">conditions tracked</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">50</span>
        <span class="stat-label">state guides</span>
      </div>
    </div>
  </div>
</div>

<!-- I'm Looking For Help With... -->
<div class="page-wrapper">
  <div class="container">

    <section class="bucket-select" aria-label="Choose a topic">
      <h2 class="section-heading">I'm Looking For Help With&hellip;</h2>
      <div class="bucket-grid">

        <a href="/va-benefits/" class="bucket-card">
          <span class="bucket-icon" aria-hidden="true">&#9733;</span>
          <h3>VA Benefits</h3>
          <p>GI Bill, VA home loans, healthcare, life insurance, pensions, and vocational rehab.</p>
        </a>

        <a href="/va-claims/" class="bucket-card">
          <span class="bucket-icon" aria-hidden="true">&#9998;</span>
          <h3>VA Claims</h3>
          <p>How to file, gather evidence, appeal a denial, and navigate the ratings process.</p>
        </a>

        <a href="/va-disability/" class="bucket-card">
          <span class="bucket-icon" aria-hidden="true">&#9876;</span>
          <h3>VA Disability Ratings</h3>
          <p>Condition-by-condition criteria, combined ratings math, and TDIU eligibility.</p>
        </a>

        <a href="/military-pay/" class="bucket-card">
          <span class="bucket-icon" aria-hidden="true">&#36;</span>
          <h3>Military Pay</h3>
          <p>Base pay tables, BAH rates, BAS, special pay, and allowances by rank.</p>
        </a>

        <a href="/military-retirement/" class="bucket-card">
          <span class="bucket-icon" aria-hidden="true">&#8981;</span>
          <h3>Military Retirement</h3>
          <p>Legacy vs BRS, SBP elections, CRSC vs CRDP, and retirement pay estimates.</p>
        </a>

        <a href="/state-benefits/" class="bucket-card">
          <span class="bucket-icon" aria-hidden="true">&#9873;</span>
          <h3>State Veterans Benefits</h3>
          <p>Property tax exemptions, tuition waivers, and state-level benefits — all 50 states.</p>
        </a>

      </div>
    </section>

    <!-- Top Tools -->
    <section aria-label="Top calculators" style="margin-bottom:3rem;">
      <h2 class="section-heading">Free VA &amp; Military Calculators</h2>
      <div class="card-grid">

        <article class="card">
          <span class="tool-icon" aria-hidden="true">&#127894;</span>
          <h3>VA Disability Rating Calculator</h3>
          <p>Estimate your combined VA disability rating using the official VA math formula — add multiple conditions.</p>
          <a href="/tools/va-disability-rating-calculator/" class="card-link">Launch Tool &rarr;</a>
        </article>

        <article class="card">
          <span class="tool-icon" aria-hidden="true">&#128176;</span>
          <h3>Military Retirement Calculator</h3>
          <p>Estimate your monthly military retirement pay under the Legacy, BRS, or REDUX retirement systems.</p>
          <a href="/tools/military-retirement-calculator/" class="card-link">Launch Tool &rarr;</a>
        </article>

        <article class="card">
          <span class="tool-icon" aria-hidden="true">&#127968;</span>
          <h3>BAH Calculator</h3>
          <p>Look up your Basic Allowance for Housing rate by zip code, rank, and dependency status.</p>
          <a href="/tools/bah-calculator/" class="card-link">Launch Tool &rarr;</a>
        </article>

      </div>
      <a href="/tools/" class="view-all-link">See all 7 calculators &rarr;</a>
    </section>

    <!-- News section -->
    {% if recent_briefings %}
    <section aria-label="Latest news" style="margin-bottom:3rem;">
      <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:0.5rem;">
        <h2 class="section-heading" style="margin-bottom:0;">Latest Briefings</h2>
        <a href="/briefing/" style="font-size:0.875rem;color:var(--sr-blue);text-decoration:none;font-weight:600;">View all &rarr;</a>
      </div>
      <div class="card-grid">
        {% for post in recent_briefings[:6] %}
        <article class="cluster-card">
          <div style="font-size:0.78rem;color:var(--sr-gray-text);margin-bottom:0.4rem;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
            <span>{{ post.published_date.strftime('%b %d, %Y') }}</span>
            {% if post.primary_sector %}
            <span class="tag" style="font-size:0.72rem;">{{ post.primary_sector | replace('_',' ') | title }}</span>
            {% endif %}
          </div>
          <h3><a href="/briefing/{{ post.slug }}/" style="text-decoration:none;color:inherit;">{{ post.title }}</a></h3>
          {% if post.summary %}
          <p>{{ post.summary[:100] }}&hellip;</p>
          {% endif %}
          <a href="/briefing/{{ post.slug }}/" class="card-link">Read analysis &rarr;</a>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}

  </div>
</div>

<!-- Footer disclaimer -->
<div style="background:var(--sr-gray-bg);border-top:1px solid var(--sr-gray-light);padding:1.25rem 0;">
  <div class="container--narrow">
    <p style="font-size:0.82rem;color:var(--sr-gray-text);text-align:center;margin:0;">
      Rank and Pay provides informational content about veterans benefits and military compensation. We are not affiliated with the U.S. Department of Veterans Affairs.
    </p>
  </div>
</div>

{% endblock %}
