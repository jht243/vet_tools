{% macro recent_briefings_rail(briefings, heading="Recent news") %}
{% if briefings %}
<section class="recent-briefings" aria-label="{{ heading }}">
  <h2 class="section-heading">{{ heading }}</h2>
  <div class="card-grid">
    {% for post in briefings[:3] %}
    <article class="briefing-card">
      <div class="briefing-card-meta">
        <span class="briefing-card-date">{{ post.published_date.strftime('%b %d, %Y') }}</span>
        {% if post.primary_sector %}
        <span class="briefing-card-sector">{{ post.primary_sector | replace('_', ' ') | title }}</span>
        {% endif %}
      </div>
      <h3><a href="/briefing/{{ post.slug }}/">{{ post.title }}</a></h3>
      {% if post.summary %}
      <p class="briefing-card-summary">{{ post.summary[:120] }}&hellip;</p>
      {% endif %}
    </article>
    {% endfor %}
  </div>
  <a href="/briefing/" class="view-all-link">View all news &rarr;</a>
</section>
{% endif %}
{% endmacro %}
