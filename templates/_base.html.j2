{# Reusable share button macro. Pages call {{ share_button(url, title) }}
   anywhere they want to render a Share affordance. The global script
   below wires up navigator.share / clipboard fallback. #}
{% macro share_button(url, title, label='Share') -%}
<button type="button" class="share-btn"
        data-share-url="{{ url }}"
        data-share-title="{{ title|e }}"
        aria-label="Share this page">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
  </svg>
  <span class="share-btn-label">{{ label }}</span>
</button>
{%- endmacro %}

{% block content %}{% endblock %}

<div class="footer-cta">
  <h3>Get the daily AI briefing in your inbox</h3>
  <p>Daily coverage of AI risk, regulation, and the human-first business case — free.</p>
  <a class="btn" href="/#newsletter">Subscribe free</a>
</div>

<footer class="site-footer">
  &copy; {{ current_year|default(2026) }} Ban the Bots ·
  <a href="/sitemap.xml">Sitemap</a> ·
  <a href="/ai-backlash/">AI Backlash</a> ·
