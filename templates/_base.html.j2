<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% set _site_name = _site_name | default("Rank and Pay") %}

  <title>{% block title %}{% if seo and seo.title %}{{ seo.title }}{% else %}{{ _site_name }}{% endif %}{% endblock %}</title>

  {% if seo %}
    {% if seo.description %}<meta name="description" content="{{ seo.description }}">{% endif %}
    {% if seo.canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endif %}
    {% if seo.noindex %}<meta name="robots" content="noindex, nofollow">{% else %}<meta name="robots" content="index, follow">{% endif %}
    <!-- Open Graph -->
    <meta property="og:type" content="{% if seo.og_type %}{{ seo.og_type }}{% else %}website{% endif %}">
    <meta property="og:title" content="{% if seo.og_title %}{{ seo.og_title }}{% else %}{{ seo.title | default(_site_name) }}{% endif %}">
    <meta property="og:description" content="{% if seo.og_description %}{{ seo.og_description }}{% else %}{{ seo.description | default('') }}{% endif %}">
    {% if seo.og_image %}<meta property="og:image" content="{{ seo.og_image }}">{% endif %}
    {% if seo.canonical %}<meta property="og:url" content="{{ seo.canonical }}">{% endif %}
    <meta property="og:site_name" content="{{ _site_name }}">
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% if seo.og_title %}{{ seo.og_title }}{% else %}{{ seo.title | default(_site_name) }}{% endif %}">
    <meta name="twitter:description" content="{% if seo.og_description %}{{ seo.og_description }}{% else %}{{ seo.description | default('') }}{% endif %}">
    {% if seo.og_image %}<meta name="twitter:image" content="{{ seo.og_image }}">{% endif %}
  {% endif %}

  {% if jsonld %}
  <script type="application/ld+json">{{ jsonld | safe }}</script>
  {% endif %}

  <!-- Google Fonts (non-blocking, font-display: optional eliminates swap-induced LCP delay) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Open+Sans:wght@400;500;600;700&display=optional" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Open+Sans:wght@400;500;600;700&display=optional"></noscript>

  <!-- Google Analytics (deferred until after load) -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RRYRHFJG2Q');
    (function(){
      var load = function(){
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-RRYRHFJG2Q';
        document.head.appendChild(s);
      };
      if ('requestIdleCallback' in window) {
        requestIdleCallback(load, {timeout: 4000});
      } else {
        window.addEventListener('load', function(){ setTimeout(load, 1500); });
      }
    })();
  </script>

  {% block extra_head %}{% endblock %}

  <style>
    /* =========================================================
       Adjusted-fallback font metrics — minimize CLS when the cached
       web font swaps in over the system fallback. Values from the
       Fontsource adjusted-font-fallback database.
    ========================================================= */
    @font-face {
      font-family: 'Open Sans Fallback';
      src: local('Arial');
      ascent-override: 101.17%;
      descent-override: 27.71%;
      line-gap-override: 0%;
      size-adjust: 101.18%;
    }
    @font-face {
      font-family: 'Libre Baskerville Fallback';
      src: local('Times New Roman'), local('Times');
      ascent-override: 97.05%;
      descent-override: 26.70%;
      line-gap-override: 0%;
      size-adjust: 105.49%;
    }

    /* =========================================================
       CSS Reset & Base
    ========================================================= */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sr-blue: #002b5e;
      --sr-blue-dark: #001f44;
      --sr-red: #cc0000;
      --sr-gray-bg: #f8f9fa;
      --sr-gray-light: #e9ecef;
      --sr-gray-text: #545b62;
      --sr-dark-text: #212529;
      --white: #ffffff;
      --font-serif: 'Libre Baskerville', 'Libre Baskerville Fallback', 'Times New Roman', Times, serif;
      --font-sans: 'Open Sans', 'Open Sans Fallback', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      --max-width: 1200px;
      --gap: 1.5rem;
      --radius: 6px;
      --shadow: 0 2px 8px rgba(0,0,0,0.10);
      --shadow-md: 0 4px 16px rgba(0,0,0,0.14);
    }

    html { font-size: 16px; scroll-behavior: smooth; }

    body {
      font-family: var(--font-sans);
      color: var(--sr-dark-text);
      background: var(--white);
      line-height: 1.7;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    a { color: var(--sr-blue); text-decoration: underline; }
    a:hover { color: var(--sr-red); }

    img { max-width: 100%; height: auto; display: block; }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-serif);
      color: var(--sr-blue);
      line-height: 1.25;
      margin-bottom: 0.5em;
    }

    p { margin-bottom: 1em; }

    ul, ol { margin-bottom: 1em; padding-left: 1.5em; }

    /* =========================================================
       Layout Containers
    ========================================================= */
    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.25rem;
    }

    .container--narrow {
      max-width: 820px;
      margin: 0 auto;
      padding: 0 1.25rem;
    }

    .page-wrapper {
      flex: 1;
      padding: 2rem 0 3rem;
    }

    /* =========================================================
       Navigation
    ========================================================= */
    .site-header {
      background: var(--sr-blue);
      color: var(--white);
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 6px rgba(0,0,0,0.25);
    }

    .nav-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 58px;
      gap: 1rem;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      color: var(--white);
      font-family: var(--font-serif);
      font-size: 1.1rem;
      font-weight: 700;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .nav-brand:hover { color: var(--sr-gray-light); }

    .nav-brand svg path:first-child { fill: var(--white); }
    .nav-brand svg path:last-child { fill: var(--sr-blue-dark); opacity: 0.4; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .nav-links a {
      display: block;
      padding: 0.45rem 0.75rem;
      color: rgba(255,255,255,0.88);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      border-radius: var(--radius);
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }

    .nav-links a:hover,
    .nav-links a.active {
      background: rgba(255,255,255,0.15);
      color: var(--white);
    }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 6px;
      border-radius: var(--radius);
    }

    .nav-hamburger:hover { background: rgba(255,255,255,0.1); }

    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--white);
      border-radius: 2px;
      transition: transform 0.25s, opacity 0.25s;
    }

    .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .nav-mobile {
      display: none;
      background: var(--sr-blue-dark);
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    .nav-mobile.open { display: block; }

    .nav-mobile ul {
      list-style: none;
      padding: 0.5rem 1.25rem 1rem;
      margin: 0;
    }

    .nav-mobile a {
      display: block;
      padding: 0.65rem 0.5rem;
      color: rgba(255,255,255,0.88);
      text-decoration: none;
      font-size: 0.95rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .nav-mobile a:last-child { border-bottom: none; }
    .nav-mobile a:hover { color: var(--white); }

    /* Nav dropdown */
    .nav-dropdown {
      position: relative;
    }

    .nav-dropdown-toggle {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.45rem 0.75rem;
      color: rgba(255,255,255,0.88);
      font-size: 0.9rem;
      font-weight: 500;
      background: none;
      border: none;
      border-radius: var(--radius);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
      font-family: inherit;
    }

    .nav-dropdown-toggle:hover,
    .nav-dropdown.open .nav-dropdown-toggle {
      background: rgba(255,255,255,0.15);
      color: var(--white);
    }

    .nav-dropdown-toggle svg {
      transition: transform 0.2s;
    }

    .nav-dropdown.open .nav-dropdown-toggle svg {
      transform: rotate(180deg);
    }

    .nav-dropdown-menu {
      display: none;
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
      list-style: none;
      margin: 0;
      padding: 0.4rem 0;
      min-width: 220px;
      z-index: 200;
    }

    .nav-dropdown.open .nav-dropdown-menu {
      display: block;
    }

    .nav-dropdown-menu a {
      display: block;
      padding: 0.55rem 1rem;
      color: var(--sr-dark-text);
      text-decoration: none;
      font-size: 0.875rem;
      font-weight: 500;
      transition: background 0.12s, color 0.12s;
    }

    .nav-dropdown-menu a:hover {
      background: var(--sr-gray-bg);
      color: var(--sr-blue);
    }

    /* Mobile nav enhancements */
    .nav-mobile-heading {
      padding: 0.5rem 0.5rem 0.25rem;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.5);
      list-style: none;
    }

    .nav-mobile-divider {
      height: 1px;
      background: rgba(255,255,255,0.1);
      margin: 0.4rem 0.5rem;
      list-style: none;
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
    }

    /* =========================================================
       Breadcrumbs
    ========================================================= */
    .breadcrumbs {
      background: var(--sr-gray-bg);
      border-bottom: 1px solid var(--sr-gray-light);
      padding: 0.6rem 0;
      font-size: 0.82rem;
      color: var(--sr-gray-text);
    }

    .breadcrumbs ol {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.2rem;
      padding: 0;
      margin: 0;
      align-items: center;
    }

    .breadcrumbs li { display: flex; align-items: center; gap: 0.2rem; }

    .breadcrumbs li + li::before {
      content: '/';
      color: var(--sr-gray-text);
      opacity: 0.6;
    }

    .breadcrumbs a { color: var(--sr-blue); text-decoration: none; }
    .breadcrumbs a:hover { text-decoration: underline; }
    .breadcrumbs [aria-current="page"] { color: var(--sr-gray-text); }

    /* =========================================================
       Cards & Grid
    ========================================================= */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--gap);
      margin-bottom: 2rem;
    }

    .card {
      background: var(--white);
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      padding: 1.5rem;
      box-shadow: var(--shadow);
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .card h3 { margin-bottom: 0.5rem; font-size: 1.05rem; }
    .card p { font-size: 0.9rem; color: var(--sr-gray-text); margin-bottom: 1rem; }

    .card-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      color: var(--sr-blue);
      font-weight: 600;
      font-size: 0.88rem;
      text-decoration: none;
    }

    .card-link:hover { color: var(--sr-red); }

    /* =========================================================
       Briefing Cards
    ========================================================= */
    .briefing-card {
      background: var(--white);
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      box-shadow: var(--shadow);
      transition: box-shadow 0.2s;
    }

    .briefing-card:hover { box-shadow: var(--shadow-md); }

    .briefing-card h3 {
      font-size: 1rem;
      margin-bottom: 0.4rem;
    }

    .briefing-card h3 a {
      color: var(--sr-blue);
      text-decoration: none;
    }

    .briefing-card h3 a:hover { color: var(--sr-red); text-decoration: underline; }

    .briefing-card-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      margin-bottom: 0.6rem;
    }

    .briefing-card-date {
      font-size: 0.8rem;
      color: var(--sr-gray-text);
    }

    .briefing-card-sector {
      font-size: 0.75rem;
      font-weight: 600;
      background: var(--sr-blue);
      color: var(--white);
      padding: 0.15rem 0.5rem;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .briefing-card-summary {
      font-size: 0.875rem;
      color: var(--sr-gray-text);
      margin: 0;
    }

    /* =========================================================
       Section headings & utility
    ========================================================= */
    .section-heading {
      font-family: var(--font-serif);
      font-size: 1.6rem;
      color: var(--sr-blue);
      margin-bottom: 1.25rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--sr-gray-light);
    }

    .view-all-link {
      display: inline-block;
      color: var(--sr-blue);
      font-weight: 600;
      font-size: 0.9rem;
      text-decoration: none;
      margin-top: 0.5rem;
    }

    .view-all-link:hover { color: var(--sr-red); text-decoration: underline; }

    .label-pill {
      display: inline-block;
      background: var(--sr-red);
      color: var(--white);
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.2rem 0.65rem;
      border-radius: 20px;
      margin-bottom: 0.75rem;
    }

    .label-pill--blue {
      background: var(--sr-blue);
    }

    /* =========================================================
       Meta strip (article)
    ========================================================= */
    .article-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      font-size: 0.83rem;
      color: var(--sr-gray-text);
      margin-bottom: 1.5rem;
      padding: 0.75rem 0;
      border-top: 1px solid var(--sr-gray-light);
      border-bottom: 1px solid var(--sr-gray-light);
    }

    .article-meta span { display: flex; align-items: center; gap: 0.3rem; }

    /* =========================================================
       Takeaways / Key Points aside
    ========================================================= */
    .takeaways {
      background: var(--sr-gray-bg);
      border-left: 4px solid var(--sr-blue);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0;
    }

    .takeaways h3 {
      font-size: 1rem;
      margin-bottom: 0.75rem;
      color: var(--sr-blue);
    }

    .takeaways ul {
      margin: 0;
      padding-left: 1.25rem;
    }

    .takeaways li {
      font-size: 0.92rem;
      margin-bottom: 0.4rem;
      color: var(--sr-dark-text);
    }

    /* =========================================================
       Article body styles
    ========================================================= */
    .article-body h2 {
      font-size: 1.45rem;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    .article-body h3 {
      font-size: 1.15rem;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .article-body p { margin-bottom: 1.1em; }

    .article-body a { color: var(--sr-blue); }
    .article-body a:hover { color: var(--sr-red); }

    .article-body ul, .article-body ol {
      margin-bottom: 1.1em;
    }

    .article-body blockquote {
      border-left: 4px solid var(--sr-blue);
      padding: 0.75rem 1.25rem;
      margin: 1.5rem 0;
      background: var(--sr-gray-bg);
      font-style: italic;
      border-radius: 0 var(--radius) var(--radius) 0;
    }

    .article-body table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .article-body th {
      background: var(--sr-blue);
      color: var(--white);
      text-align: left;
      padding: 0.6rem 0.85rem;
      font-family: var(--font-sans);
    }

    .article-body td {
      padding: 0.55rem 0.85rem;
      border-bottom: 1px solid var(--sr-gray-light);
    }

    .article-body tr:nth-child(even) td { background: var(--sr-gray-bg); }

    /* =========================================================
       Share button
    ========================================================= */
    .share-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      margin: 1.5rem 0;
    }

    .share-row-label {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--sr-gray-text);
    }

    .share-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.35rem 0.8rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.15s;
      color: var(--white);
    }

    .share-btn:hover { opacity: 0.88; color: var(--white); }
    .share-btn--x { background: #000; }
    .share-btn--fb { background: #1877f2; }
    .share-btn--copy { background: var(--sr-blue); cursor: pointer; border: none; }

    /* =========================================================
       FAQ Accordion
    ========================================================= */
    .faq-section { margin: 2rem 0; }

    .faq-section h2 {
      font-size: 1.4rem;
      margin-bottom: 1rem;
    }

    .faq-item {
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      margin-bottom: 0.5rem;
      overflow: hidden;
    }

    .faq-item summary {
      padding: 1rem 1.25rem;
      cursor: pointer;
      font-weight: 600;
      font-size: 0.95rem;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--sr-gray-bg);
      color: var(--sr-blue);
      user-select: none;
    }

    .faq-item summary::-webkit-details-marker { display: none; }

    .faq-item summary::after {
      content: '+';
      font-size: 1.2rem;
      font-weight: 400;
      color: var(--sr-blue);
      transition: transform 0.2s;
    }

    .faq-item[open] summary::after { content: '−'; }

    .faq-item[open] summary {
      border-bottom: 1px solid var(--sr-gray-light);
      background: var(--white);
    }

    .faq-answer {
      padding: 1rem 1.25rem;
      font-size: 0.92rem;
      line-height: 1.7;
    }

    .faq-answer p:last-child { margin-bottom: 0; }

    /* =========================================================
       Newsletter / CTA strip
    ========================================================= */
    .newsletter-strip {
      background: var(--sr-blue);
      color: var(--white);
      padding: 2.5rem 0;
      text-align: center;
    }

    .newsletter-strip h2 {
      color: var(--white);
      font-size: 1.4rem;
      margin-bottom: 0.5rem;
    }

    .newsletter-strip p {
      color: rgba(255,255,255,0.82);
      font-size: 0.95rem;
      margin-bottom: 1.25rem;
    }

    .newsletter-form {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .newsletter-form input[type="email"] {
      padding: 0.65rem 1rem;
      border: none;
      border-radius: var(--radius);
      font-size: 0.95rem;
      width: 280px;
      max-width: 100%;
      font-family: var(--font-sans);
    }

    .newsletter-form input[type="email"]:focus {
      outline: 3px solid rgba(255,255,255,0.6);
    }

    .btn {
      display: inline-block;
      padding: 0.65rem 1.5rem;
      border-radius: var(--radius);
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      border: none;
      text-decoration: none;
      font-family: var(--font-sans);
      transition: background 0.15s, transform 0.1s;
    }

    .btn:active { transform: scale(0.98); }

    .btn--primary {
      background: var(--sr-red);
      color: var(--white);
    }

    .btn--primary:hover { background: #a80000; color: var(--white); }

    .btn--secondary {
      background: var(--white);
      color: var(--sr-blue);
    }

    .btn--secondary:hover { background: var(--sr-gray-light); color: var(--sr-blue); }

    .btn--outline {
      background: transparent;
      color: var(--white);
      border: 2px solid var(--white);
    }

    .btn--outline:hover { background: rgba(255,255,255,0.12); color: var(--white); }

    /* =========================================================
       Source attribution
    ========================================================= */
    .source-attribution {
      font-size: 0.82rem;
      color: var(--sr-gray-text);
      border-top: 1px solid var(--sr-gray-light);
      padding-top: 1rem;
      margin-top: 1.5rem;
    }

    .source-attribution a { color: var(--sr-blue); }

    /* =========================================================
       Feedback pill (floating)
    ========================================================= */
    .feedback-pill {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 200;
    }

    .feedback-pill-btn {
      background: var(--sr-blue);
      color: var(--white);
      border: none;
      border-radius: 24px;
      padding: 0.55rem 1.1rem;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      box-shadow: var(--shadow-md);
      font-family: var(--font-sans);
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: background 0.15s, transform 0.1s;
    }

    .feedback-pill-btn:hover { background: var(--sr-blue-dark); transform: scale(1.03); }

    /* Feedback Modal */
    .feedback-modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 300;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 1.5rem;
    }

    .feedback-modal-overlay.open { display: flex; }

    .feedback-modal {
      background: var(--white);
      border-radius: var(--radius);
      padding: 1.5rem;
      width: 100%;
      max-width: 360px;
      box-shadow: var(--shadow-md);
    }

    .feedback-modal h3 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .feedback-modal p {
      font-size: 0.85rem;
      color: var(--sr-gray-text);
      margin-bottom: 1rem;
    }

    .feedback-modal label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 0.3rem;
    }

    .feedback-modal textarea,
    .feedback-modal input[type="email"] {
      width: 100%;
      padding: 0.55rem 0.75rem;
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      font-size: 0.9rem;
      font-family: var(--font-sans);
      margin-bottom: 0.75rem;
      resize: vertical;
    }

    .feedback-modal textarea:focus,
    .feedback-modal input[type="email"]:focus {
      outline: 2px solid var(--sr-blue);
      border-color: var(--sr-blue);
    }

    .feedback-modal-close {
      float: right;
      background: none;
      border: none;
      font-size: 1.2rem;
      cursor: pointer;
      color: var(--sr-gray-text);
      line-height: 1;
      padding: 0 0.25rem;
    }

    .feedback-honeypot { display: none !important; }

    .feedback-modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    /* =========================================================
       Footer
    ========================================================= */
    .site-footer {
      background: var(--sr-blue-dark);
      color: rgba(255,255,255,0.75);
      padding: 2.5rem 0 1.5rem;
      margin-top: auto;
      font-size: 0.85rem;
    }

    .footer-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.25rem;
    }

    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      margin-bottom: 1.25rem;
    }

    @media (max-width: 640px) {
      .footer-top { grid-template-columns: 1fr; gap: 1.25rem; }
    }

    .footer-brand {
      font-family: var(--font-serif);
      font-size: 1rem;
      font-weight: 700;
      color: var(--white);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .footer-brand svg path:first-child { fill: var(--white); }

    .footer-desc { line-height: 1.6; }

    .footer-col h4 {
      color: var(--white);
      font-family: var(--font-sans);
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.75rem;
    }

    .footer-col ul { list-style: none; padding: 0; margin: 0; }

    .footer-col li { margin-bottom: 0.4rem; }

    .footer-col a {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
    }

    .footer-col a:hover { color: var(--white); }

    .footer-bottom {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
    }

    .footer-bottom a { color: rgba(255,255,255,0.6); }
    .footer-bottom a:hover { color: var(--white); }

    .footer-powered {
      font-size: 0.68rem;
      color: rgba(255,255,255,0.28);
      letter-spacing: 0.02em;
    }
    .footer-powered a {
      color: rgba(255,255,255,0.38);
      text-decoration: none;
    }
    .footer-powered a:hover { color: rgba(255,255,255,0.65); }

    /* =========================================================
       Hero
    ========================================================= */
    .hero {
      background: linear-gradient(135deg, var(--sr-blue) 0%, var(--sr-blue-dark) 100%);
      color: var(--white);
      padding: 2.5rem 0 2rem;
      text-align: center;
    }

    .hero h1 {
      color: var(--white);
      font-size: clamp(1.3rem, 2.6vw, 1.85rem);
      margin-bottom: 0.75rem;
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.2;
    }

    .hero p {
      color: rgba(255,255,255,0.85);
      font-size: clamp(0.875rem, 1.3vw, 1rem);
      max-width: 820px;
      margin: 0 auto 1.75rem;
      line-height: 1.4;
    }

    .hero-cta {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* =========================================================
       Stats strip
    ========================================================= */
    .stats-strip {
      background: var(--sr-gray-bg);
      border-top: 1px solid var(--sr-gray-light);
      border-bottom: 1px solid var(--sr-gray-light);
      padding: 1.75rem 0;
    }

    .stats-strip-inner {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 3rem;
    }

    .stat-item { text-align: center; }

    .stat-number {
      font-family: var(--font-serif);
      font-size: 2rem;
      font-weight: 700;
      color: var(--sr-blue);
      display: block;
    }

    .stat-label {
      font-size: 0.85rem;
      color: var(--sr-gray-text);
    }

    /* =========================================================
       Recent briefings section
    ========================================================= */
    .recent-briefings { margin: 2rem 0; }

    /* =========================================================
       Cluster / content sections
    ========================================================= */
    /* =========================================================
       Bucket select (homepage "I'm Looking For Help With...")
    ========================================================= */
    .bucket-select { margin-bottom: 3rem; }

    /* Quiz CTA banner */
    .quiz-cta-banner {
      display: flex;
      align-items: center;
      gap: 1rem;
      background: linear-gradient(135deg, #e8f5e9 0%, #d7ecd9 100%);
      border: 1px solid #81c784;
      border-left: 4px solid #2e7d32;
      border-radius: var(--radius);
      padding: 1rem 1.25rem;
      margin-bottom: 1.75rem;
      text-decoration: none;
      color: var(--sr-dark-text);
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .quiz-cta-banner:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
      color: var(--sr-dark-text);
    }

    .quiz-cta-icon {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #2e7d32;
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .quiz-cta-body { flex: 1; }
    .quiz-cta-body h3 { font-size: 1rem; margin-bottom: 0.15rem; color: var(--sr-dark-text); }
    .quiz-cta-body p { font-size: 0.85rem; color: var(--sr-gray-text); margin: 0; }

    .quiz-cta-arrow {
      font-size: 1.4rem;
      color: #2e7d32;
      font-weight: 700;
      flex-shrink: 0;
    }

    .bucket-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .bucket-card {
      display: block;
      text-decoration: none;
      color: inherit;
      background: var(--white);
      border: 2px solid var(--sr-gray-light);
      border-radius: var(--radius);
      padding: 1.5rem;
      text-align: center;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    }

    .bucket-card:hover {
      border-color: var(--sr-blue);
      box-shadow: var(--shadow-md);
      transform: translateY(-3px);
    }

    .bucket-icon {
      display: block;
      font-size: 2rem;
      margin-bottom: 0.5rem;
      color: var(--sr-blue);
    }

    .bucket-card h3 {
      font-size: 1rem;
      color: var(--sr-blue);
      margin-bottom: 0.35rem;
    }

    .bucket-card p {
      font-size: 0.82rem;
      color: var(--sr-gray-text);
      line-height: 1.5;
      margin: 0;
    }

    @media (max-width: 768px) {
      .bucket-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 480px) {
      .bucket-grid { grid-template-columns: 1fr; }
    }

    .content-clusters { margin: 2.5rem 0; }

    .cluster-card {
      background: var(--white);
      border: 1px solid var(--sr-gray-light);
      border-top: 3px solid var(--sr-blue);
      border-radius: var(--radius);
      padding: 1.5rem;
      box-shadow: var(--shadow);
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .cluster-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .cluster-card h3 { font-size: 1.05rem; margin-bottom: 0.4rem; }
    .cluster-card p { font-size: 0.875rem; color: var(--sr-gray-text); margin-bottom: 0.75rem; }

    /* =========================================================
       Tool cards
    ========================================================= */
    .tool-icon {
      font-size: 2rem;
      margin-bottom: 0.75rem;
      display: block;
    }

    .status-pill {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.15rem 0.55rem;
      border-radius: 20px;
      background: var(--sr-gray-light);
      color: var(--sr-gray-text);
    }

    .status-pill--live {
      background: #d4edda;
      color: #155724;
    }

    /* =========================================================
       Sidebar layout (article + landing)
    ========================================================= */
    .layout-with-sidebar {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 2.5rem;
      align-items: start;
    }

    @media (max-width: 900px) {
      .layout-with-sidebar {
        grid-template-columns: 1fr;
      }

      .layout-sidebar { order: -1; }
    }

    .layout-sidebar {
      position: sticky;
      top: 78px;
    }

    /* =========================================================
       TOC
    ========================================================= */
    .toc-aside {
      background: var(--sr-gray-bg);
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin-bottom: 1.5rem;
    }

    .toc-aside h3 {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
      color: var(--sr-gray-text);
    }

    .toc-aside ol, .toc-aside ul {
      margin: 0;
      padding-left: 1.25rem;
    }

    .toc-aside li { margin-bottom: 0.35rem; }

    .toc-aside a {
      color: var(--sr-blue);
      font-size: 0.875rem;
      text-decoration: none;
    }

    .toc-aside a:hover { text-decoration: underline; color: var(--sr-red); }

    .toc-inline {
      background: var(--sr-gray-bg);
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    }

    .toc-inline h2 {
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
    }

    .toc-inline ol {
      margin: 0;
      padding-left: 1.25rem;
      columns: 2;
      column-gap: 2rem;
    }

    .toc-inline li { margin-bottom: 0.35rem; }

    .toc-inline a {
      color: var(--sr-blue);
      font-size: 0.875rem;
      text-decoration: none;
    }

    .toc-inline a:hover { text-decoration: underline; color: var(--sr-red); }

    @media (max-width: 580px) {
      .toc-inline ol { columns: 1; }
    }

    /* =========================================================
       Disclaimer
    ========================================================= */
    .page-disclaimer {
      background: var(--sr-gray-bg);
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      font-size: 0.82rem;
      color: var(--sr-gray-text);
      margin-top: 2rem;
    }

    /* =========================================================
       Pagination
    ========================================================= */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      margin: 2rem 0;
    }

    .pagination a, .pagination span {
      padding: 0.5rem 1rem;
      border: 1px solid var(--sr-gray-light);
      border-radius: var(--radius);
      font-size: 0.9rem;
      text-decoration: none;
      color: var(--sr-blue);
    }

    .pagination span { color: var(--sr-gray-text); background: var(--sr-gray-bg); }
    .pagination a:hover { background: var(--sr-blue); color: var(--white); border-color: var(--sr-blue); }

    /* =========================================================
       Post list (blog index)
    ========================================================= */
    .post-list { margin-bottom: 2rem; }

    .post-list-item {
      padding: 1.25rem 0;
      border-bottom: 1px solid var(--sr-gray-light);
    }

    .post-list-item:last-child { border-bottom: none; }

    .post-list-item h3 {
      font-size: 1.05rem;
      margin-bottom: 0.3rem;
    }

    .post-list-item h3 a {
      color: var(--sr-blue);
      text-decoration: none;
    }

    .post-list-item h3 a:hover { color: var(--sr-red); text-decoration: underline; }

    .post-list-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      margin-bottom: 0.5rem;
    }

    .post-list-date { font-size: 0.8rem; color: var(--sr-gray-text); }

    .post-list-summary { font-size: 0.875rem; color: var(--sr-gray-text); }

    /* =========================================================
       Responsive helpers
    ========================================================= */
    @media (max-width: 640px) {
      .card-grid { grid-template-columns: 1fr; }
      .stats-strip-inner { gap: 1.5rem; }
      .hero { padding: 2.5rem 0 2rem; }
    }
  </style>
</head>
<body>

<!-- Google Tag Manager (noscript) -->

