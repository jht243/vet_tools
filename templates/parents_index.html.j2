{% extends "_base.html.j2" %}

{% block page_hero %}
<div class="page-hero-strip">
  <div class="page-hero-inner">
    <div class="page-hero-eyebrow">Ban the Bots · For Parents</div>
    <h1 class="page-hero-title">Parenting in the Age of AI</h1>
    <p class="page-hero-subtitle">
      AI is reshaping childhood fast — what kids learn, how they spend their time online,
      and what jobs they'll have. You have questions. Here are real answers.
    </p>
  </div>
</div>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>For Parents</span>
  </nav>

  {% set _spokes = [
    {
      "slug": "screen-time",
      "label": "AI & Screen Time",
      "icon": "📱",
      "summary": "AI-powered apps are designed to keep kids hooked. What the research says about screen time, algorithm-driven feeds, and what parents can actually do about it."
    },
    {
      "slug": "what-to-study",
      "label": "What Should My Kids Study?",
      "icon": "🎓",
      "summary": "With AI automating so many jobs, what skills will actually matter? A plain-English guide to future-proof subjects, degrees, and skills — based on real labor research."
    },
    {
      "slug": "ai-safety",
      "label": "AI Safety for Kids",
      "icon": "🛡️",
      "summary": "Deepfakes, AI-generated inappropriate content, grooming via AI chatbots. The risks are real — here's what to watch for and how to talk to your kids about it."
    },
    {
      "slug": "how-to-use-ai-for-good",
      "label": "Using AI for Good",
      "icon": "✅",
      "summary": "AI can be a genuine learning tool or a homework-avoidance machine. How to help your kids use it as a tutor, not a crutch — and what questions to ask their school."
    },
    {
      "slug": "social-media",
      "label": "AI & Social Media",
      "icon": "🌀",
      "summary": "The recommendation algorithms behind TikTok, YouTube, and Instagram are AI systems optimized for engagement, not wellbeing. What that means for your child's mental health."
    }
  ] %}

  <div class="index-grid">
    {% for spoke in _spokes %}
    <article class="index-card">
      <a class="card-link" href="/parents/{{ spoke.slug }}/" aria-label="{{ spoke.label }}"></a>
      <div class="meta" style="text-transform:uppercase; letter-spacing:0.8px; color:#cc0000; font-weight:700; font-size:11px;">
        Parent guide
      </div>
      <a class="title-link" href="/parents/{{ spoke.slug }}/">
        <span aria-hidden="true" style="margin-right:6px;">{{ spoke.icon }}</span>{{ spoke.label }}
      </a>
      <p class="summary">{{ spoke.summary }}</p>
      <p style="font-size:13px; color:var(--sr-blue); font-weight:600; margin-top:4px;">Read guide →</p>
    </article>
    {% endfor %}
  </div>

  <div style="margin:40px 0 24px; padding:20px 24px; background:var(--sr-gray-bg); border-left:3px solid var(--sr-blue); border-radius:3px; font-size:15px; color:var(--sr-dark-text); line-height:1.7;">
    <strong>Worried about your kids' future jobs?</strong>
    Our <a href="/ai-proof-jobs/" style="font-weight:600;">AI-Proof Jobs guide</a> breaks down which careers are genuinely resilient —
    and our <a href="/will-ai-replace-my-job/" style="font-weight:600;">job checker tool</a> lets you look up any occupation.
    You can also track <a href="/ai-layoffs/">which companies are cutting jobs because of AI</a> right now.
  </div>

</section>
{% endblock %}
