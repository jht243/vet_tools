      { url: '/va-claims/secondary-conditions/', text: 'Secondary Conditions Guide' },
      { url: '/va-claims/nexus-letter-guide/', text: 'Nexus Letter Guide' },
      { url: '/va-claims/how-to-file-a-va-claim/', text: 'Filing Guide' },
      { url: '/tools/va-disability-rating-calculator/', text: 'Calculate Your Combined Rating' }
    ]
  }
};

/* Step order for progress tracking */
const STEP_DEPTHS = {
  start: 1,
  active_duty: 2, separated: 2, guard_reserve: 2,
  previous_claims: 3,
  condition_type: 4
};
const MAX_STEPS = 4;

let history = [];
let currentNode = 'start';

function getProgressPercent(nodeId) {
  const depth = STEP_DEPTHS[nodeId] || MAX_STEPS;
  return Math.round((depth / MAX_STEPS) * 100);
}

function renderQuestion(nodeId, animate) {
  const node = TREE[nodeId];
  if (!node) return;

  currentNode = nodeId;

  const resultEl = document.getElementById('tree-result');
  resultEl.style.display = 'none';

  const progressEl = document.getElementById('tree-progress');
  const questionEl = document.getElementById('tree-question');
  const navEl = document.getElementById('tree-nav');
  const backBtn = document.getElementById('tree-back-btn');

  if (node.result) {
    progressEl.style.display = 'none';
    questionEl.style.display = 'none';
    navEl.style.display = 'none';
    renderResult(node);
    return;
  }

  progressEl.style.display = 'flex';
  questionEl.style.display = 'block';
  navEl.style.display = 'flex';

  const depth = STEP_DEPTHS[nodeId] || 1;
  document.getElementById('tree-step-label').textContent = 'Step ' + depth + ' of ' + MAX_STEPS;
  document.getElementById('tree-progress-bar').style.width = getProgressPercent(nodeId) + '%';

  backBtn.style.display = history.length > 0 ? 'inline-flex' : 'none';

  if (animate) {
    questionEl.style.opacity = '0';
    setTimeout(function() {
      questionEl.innerHTML = buildQuestionHTML(node);
      questionEl.style.opacity = '1';
    }, 150);
  } else {
    questionEl.innerHTML = buildQuestionHTML(node);
  }
}

function buildQuestionHTML(node) {
  let html = '<h2 style="font-size:1.15rem;margin-bottom:1.25rem;border-bottom:2px solid var(--sr-blue);padding-bottom:0.5rem;">' + escapeHTML(node.question) + '</h2>';
  html += '<div style="display:flex;flex-direction:column;gap:0.6rem;">';
  node.options.forEach(function(opt, i) {
    html += '<label style="display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1rem;border:1px solid var(--sr-gray-light);border-radius:var(--radius);cursor:pointer;transition:border-color 0.2s,background 0.2s;" ' +
      'onmouseover="this.style.borderColor=\'var(--sr-blue)\';this.style.background=\'var(--sr-gray-bg)\'" ' +
      'onmouseout="this.style.borderColor=\'var(--sr-gray-light)\';this.style.background=\'#fff\'">' +
      '<input type="radio" name="tree-choice" value="' + i + '" ' +
      'onchange="selectOption(\'' + opt.next + '\')" ' +
      'style="accent-color:var(--sr-blue);width:18px;height:18px;flex-shrink:0;">' +
      '<span style="font-size:0.95rem;color:var(--sr-dark-text);">' + escapeHTML(opt.label) + '</span>' +
      '</label>';
  });
  html += '</div>';
  return html;
}

function selectOption(nextNodeId) {
  history.push(currentNode);
  setTimeout(function() {
    renderQuestion(nextNodeId, true);
  }, 200);
}

function goBack() {
  if (history.length === 0) return;
  const prev = history.pop();
  renderQuestion(prev, true);
}

function startOver() {
  history = [];
  renderQuestion('start', true);
}

function renderResult(node) {
  const resultEl = document.getElementById('tree-result');

  let bannerColor, bannerBg, bannerBorder, bannerIcon;
  switch (node.level) {
    case 'eligible':
      bannerBg = '#d4edda'; bannerBorder = '#28a745'; bannerColor = '#155724'; bannerIcon = '✅';
      break;
    case 'caution':
      bannerBg = '#fff3cd'; bannerBorder = '#ffc107'; bannerColor = '#856404'; bannerIcon = '⚠️';
      break;
    case 'ineligible':
      bannerBg = '#f8d7da'; bannerBorder = '#dc3545'; bannerColor = '#721c24'; bannerIcon = '❌';
      break;
    default:
      bannerBg = '#d4edda'; bannerBorder = '#28a745'; bannerColor = '#155724'; bannerIcon = '✅';
  }

  let html = '<div style="background:' + bannerBg + ';border:2px solid ' + bannerBorder + ';border-radius:var(--radius);padding:1.25rem;margin-bottom:1.25rem;">';
  html += '<div style="font-size:1.2rem;font-weight:700;color:' + bannerColor + ';margin-bottom:0.4rem;">' + bannerIcon + ' ' + escapeHTML(node.title) + '</div>';
  html += '<p style="color:' + bannerColor + ';margin:0;font-size:0.95rem;line-height:1.6;">' + escapeHTML(node.summary) + '</p>';
  html += '</div>';

  html += '<h3 style="font-size:1.05rem;margin-bottom:0.75rem;color:var(--sr-dark-text);">Recommended Next Steps</h3>';
  html += '<ol style="padding-left:1.25rem;margin-bottom:1.25rem;">';
  node.steps.forEach(function(step) {
    html += '<li style="margin-bottom:0.5rem;line-height:1.5;color:var(--sr-dark-text);">' + escapeHTML(step) + '</li>';
  });
  html += '</ol>';

  if (node.links && node.links.length > 0) {
    html += '<div style="background:var(--sr-gray-bg);border:1px solid var(--sr-gray-light);border-radius:var(--radius);padding:1rem;margin-bottom:1.25rem;">';
    html += '<h4 style="font-size:0.9rem;margin-bottom:0.5rem;color:var(--sr-gray-text);text-transform:uppercase;letter-spacing:0.04em;">Helpful Resources</h4>';
    html += '<ul style="margin:0;padding-left:1.25rem;">';
    node.links.forEach(function(link) {
      html += '<li style="margin-bottom:0.35rem;"><a href="' + escapeAttr(link.url) + '" style="color:var(--sr-blue);text-decoration:none;font-weight:500;">' + escapeHTML(link.text) + ' &rarr;</a></li>';
    });
    html += '</ul>';
    html += '</div>';
  }

  html += '<div style="display:flex;gap:0.75rem;flex-wrap:wrap;">';
  html += '<button onclick="startOver()" style="background:var(--sr-blue);color:#fff;border:none;padding:0.6rem 1.25rem;border-radius:var(--radius);cursor:pointer;font-size:0.9rem;font-weight:600;">Start Over</button>';
  html += '<button onclick="goBack()" style="background:none;border:1px solid var(--sr-gray-light);border-radius:var(--radius);padding:0.6rem 1.25rem;cursor:pointer;font-size:0.9rem;color:var(--sr-gray-text);font-weight:600;">&larr; Go Back</button>';
  html += '</div>';

  resultEl.innerHTML = html;
  resultEl.style.display = 'block';

  resultEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function escapeHTML(str) {
  const div = document.createElement('div');
  div.appendChild(document.createTextNode(str));
  return div.innerHTML;
}

function escapeAttr(str) {
  return str.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* Initialize */
renderQuestion('start', false);
</script>
{% endblock %}
