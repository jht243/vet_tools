{% extends "_base.html.j2" %}
{% block title %}{{ seo.title }}{% endblock %}

{% block content %}
<section class="hero" style="padding:2.5rem 0 2rem;">
  <div class="container">
    <h1>{{ page.subtitle or page.title }}</h1>
    {% if page.summary %}<p style="opacity:0.9;max-width:600px;margin:0.5rem auto 0;">{{ page.summary }}</p>{% endif %}
  </div>
</section>

<main class="container" style="max-width:1040px;margin:2rem auto;padding:0 1.25rem;">

  <!-- Breadcrumb -->
  {% if breadcrumbs %}
  <nav aria-label="Breadcrumb" style="font-size:0.82rem;margin-bottom:1.5rem;color:var(--sr-gray-text);">
    {% for crumb in breadcrumbs %}
    {% if not loop.last %}
    <a href="{{ crumb.url }}">{{ crumb.label }}</a> &rsaquo;
    {% else %}
    <span>{{ crumb.label }}</span>
    {% endif %}
    {% endfor %}
  </nav>
  {% endif %}

  <!-- Intro -->
  {% if intro_heading %}
  <section style="margin-bottom:1.75rem;">
    <h2 class="section-heading">{{ intro_heading }}</h2>
    {% if intro_text %}<p style="font-size:0.95rem;color:var(--sr-gray-text);line-height:1.6;max-width:720px;">{{ intro_text }}</p>{% endif %}
  </section>
  {% endif %}

  <!-- Spoke cards -->
  {% if spokes %}
  <section class="bucket-select" aria-label="Topics in this guide">
    <div class="bucket-grid">
      {% for s in spokes %}
      <a href="{{ s.url }}" class="bucket-card">
        {% if s.icon %}<span class="bucket-icon" aria-hidden="true">{{ s.icon }}</span>{% endif %}
        <h3>{{ s.label }}</h3>
        {% if s.description %}<p>{{ s.description }}</p>{% endif %}
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <!-- Body (below the fold) -->
  {% if page.body_html %}
  <div class="article-body" style="line-height:1.75;margin-top:2rem;">
    {{ page.body_html | safe }}
  </div>
  {% endif %}

  <!-- FAQ accordion -->
  {% if faq %}
  <section style="margin-top:2.5rem;" aria-labelledby="faq-heading">
    <h2 id="faq-heading">Frequently Asked Questions</h2>
    <div class="faq-list">
      {% for item in faq %}
      <details class="faq-item">
        <summary>{{ item.question }}</summary>
        <div style="padding:0.75rem 1.25rem 1rem;font-size:0.9rem;line-height:1.6;color:var(--sr-dark-text);">
          {{ item.answer }}
        </div>
      </details>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <!-- Email capture -->
  <div style="background:var(--sr-blue);color:var(--white);border-radius:var(--radius);padding:1.5rem 2rem;margin-top:2.5rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
    <div style="flex:1;min-width:200px;">
      <h3 style="color:var(--white);font-size:1rem;margin-bottom:0.25rem;">Get free daily updates</h3>
      <p style="font-size:0.85rem;opacity:0.85;margin:0;line-height:1.4;">VA policy changes and benefit rate updates — delivered to your inbox.</p>
    </div>
    <form action="/api/subscribe" method="POST" style="display:flex;gap:0.5rem;flex:1;min-width:260px;">
      <input type="email" name="email" placeholder="you@example.com" required
             style="flex:1;padding:0.55rem 0.75rem;border-radius:var(--radius);border:none;font-size:0.875rem;">
      <button type="submit" class="btn btn--primary" style="background:var(--sr-red);border-color:var(--sr-red);white-space:nowrap;">Subscribe</button>
    </form>
  </div>

  <!-- Disclaimer -->
  <div class="page-disclaimer" style="margin-top:2rem;">
    <strong>Disclaimer:</strong> Rank and Pay provides general information only and is not a
    law firm. Nothing on this site constitutes legal, financial, or benefits advice. Always
    verify information with the VA or an accredited claims agent.
  </div>

</main>
{% endblock %}
