{% extends "_base.html.j2" %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Analysis</span>
  </nav>

  <header style="margin: 16px 0 32px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Ban the Bots · Daily AI briefings
    </div>
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--sr-blue-dark); margin:8px 0 12px;">
      AI Risk &amp; Responsible AI: Daily Briefings
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:18px; max-width:680px;">
      Plain-English coverage of AI regulation, labor disruption, environmental impact,
      content quality risks, and real-world AI incidents — for business owners who
      need the facts without the hype.
    </p>
  </header>

  {% if posts %}
  <div class="cr-search-panel" role="search" aria-label="Search analysis archive">
    <label class="cr-search-label" for="briefing-search">Search analysis</label>
    <div class="cr-search-row">
      <input type="search" id="briefing-search" placeholder="Search AI regulation, labor, energy, incidents…" autocomplete="off">
    </div>
  </div>

  <div class="cr-empty-filter" id="briefing-empty">No analysis posts match that search.</div>

  <div class="index-grid">
    {% for p in posts %}
    <article class="index-card" data-search="{{ (p.title ~ ' ' ~ (p.summary or '') ~ ' ' ~ (p.primary_sector or ''))|lower }}">
      {% if p.primary_sector %}
      <div class="meta">{{ p.primary_sector|replace('_',' ')|title }} · {{ p.published_date.strftime('%b %d, %Y') }}</div>
      {% else %}
      <div class="meta">{{ p.published_date.strftime('%b %d, %Y') }}</div>
      {% endif %}
      <a class="title-link" href="/briefing/{{ p.slug }}">{{ p.title }}</a>
      {% if p.summary %}<p class="summary">{{ p.summary }}</p>{% endif %}
    </article>
    {% endfor %}
  </div>

  {% if total_pages is defined and total_pages > 1 %}
  <nav class="pagination" aria-label="Briefing pages">
    {% if page > 1 %}
      <a href="/briefing{{ '?page=%d' % (page - 1) if page > 2 else '' }}" class="pagination-link" rel="prev">&larr; Newer</a>
    {% else %}
      <span class="pagination-link disabled">&larr; Newer</span>
    {% endif %}

    <span class="pagination-info">Page {{ page }} of {{ total_pages }}</span>

    {% if page < total_pages %}
      <a href="/briefing?page={{ page + 1 }}" class="pagination-link" rel="next">Older &rarr;</a>
    {% else %}
      <span class="pagination-link disabled">Older &rarr;</span>
    {% endif %}
  </nav>
  {% endif %}

  {% else %}
  <p style="color: var(--sr-gray-text); padding: 32px 0;">
    No briefings published yet — the next batch will appear after the
    daily pipeline runs at 9:00 AM and 4:00 PM ET.
  </p>
  {% endif %}

</section>

<script>
(function () {
  var input = document.getElementById('briefing-search');
  var empty = document.getElementById('briefing-empty');
  if (!input) return;
  var cards = Array.prototype.slice.call(document.querySelectorAll('.index-card[data-search]'));
  input.addEventListener('input', function () {
    var q = input.value.trim().toLowerCase();
    var visible = 0;
    cards.forEach(function (card) {
      var show = !q || (card.getAttribute('data-search') || '').indexOf(q) !== -1;
      card.style.display = show ? '' : 'none';
      if (show) visible += 1;
    });
    if (empty) empty.style.display = q && visible === 0 ? 'block' : 'none';
  });
})();
</script>
{% endblock %}
