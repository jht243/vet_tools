{% extends "_base.html.j2" %}
{% block title %}{{ seo.title }}{% endblock %}
{% block meta_description %}{{ seo.description }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endblock %}
{% block og_tags %}
<meta property="og:title" content="{{ seo.title | e }}">
<meta property="og:description" content="{{ seo.description | e }}">
<meta property="og:url" content="{{ seo.canonical }}">
<meta property="og:type" content="website">
{% endblock %}
{% block extra_head %}
<link rel="alternate" type="application/atom+xml" title="VA Claims Workspace Briefings" href="/briefing/feed.xml">
{% endblock %}

{% block content %}
<section class="hero" style="padding:2.5rem 0 2rem;">
  <div class="container">
    <h1>VA &amp; Military Benefits Briefings</h1>
    <p>Daily plain-English analysis of VA policy, disability rates, and military compensation changes.</p>
  </div>
</section>

<main class="container" style="max-width:760px;margin:2rem auto;padding:0 1.25rem;">

  {% if posts %}
  <div class="post-list">
    {% for post in posts %}
    <article class="post-list-item">
      <div class="post-list-meta">
        <span class="post-list-date">{{ post.published_date.strftime('%B %d, %Y') }}</span>
        {% if post.primary_sector %}
        <span class="tag">{{ post.primary_sector | replace('_', ' ') | title }}</span>
        {% endif %}
      </div>
      <h2><a href="/briefing/{{ post.slug }}/">{{ post.title }}</a></h2>
      {% if post.summary %}
      <p class="post-list-summary">{{ post.summary[:160] }}…</p>
      {% endif %}
    </article>
    {% endfor %}
  </div>

  <nav class="pagination" aria-label="Page navigation">
    {% if page > 1 %}
    <a href="/briefing/?page={{ page - 1 }}" rel="prev">&larr; Newer</a>
    {% else %}
    <span>&larr; Newer</span>
    {% endif %}

    <span>Page {{ page }} of {{ total_pages }}</span>

    {% if page < total_pages %}
    <a href="/briefing/?page={{ page + 1 }}" rel="next">Older &rarr;</a>
    {% else %}
    <span>Older &rarr;</span>
    {% endif %}
  </nav>

  {% else %}
  <p style="color:var(--sr-gray-text);text-align:center;padding:3rem 0;">No briefings yet — check back soon.</p>
  {% endif %}

</main>
{% endblock %}
