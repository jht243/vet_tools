{% extends "_base.html.j2" %}
{% from "_cluster_nav.html.j2" import cluster_nav %}
{% block title %}{{ seo.title }}{% endblock %}
{# seo dict is handled in _base.html.j2 head — canonical, description, OG, JSON-LD all auto-rendered #}

{% block content %}
<section class="hero" style="padding:2.5rem 0 2rem;">
  <div class="container">
    <h1>{{ page.subtitle or page.title }}</h1>
    {% if page.summary %}<p style="opacity:0.9;max-width:600px;margin:0.5rem auto 0;">{{ page.summary }}</p>{% endif %}
  </div>
</section>

<main class="container" style="max-width:1040px;margin:2rem auto;padding:0 1.25rem;">
  <div class="layout-with-sidebar">

    <!-- Main content -->
    <div>
      <!-- Breadcrumb -->
      {% if breadcrumbs %}
      <nav aria-label="Breadcrumb" style="font-size:0.82rem;margin-bottom:1.25rem;color:var(--sr-gray-text);">
        {% for crumb in breadcrumbs %}
        {% if not loop.last %}
        <a href="{{ crumb.url }}">{{ crumb.label }}</a> &rsaquo;
        {% else %}
        <span>{{ crumb.label }}</span>
        {% endif %}
        {% endfor %}
      </nav>
      {% endif %}

      <!-- Key takeaways -->
      {% if page.key_takeaways %}
      <aside style="background:var(--sr-gray-bg);border:1px solid var(--sr-gray-light);border-left:4px solid var(--sr-blue);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:1.75rem;">
        <h2 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--sr-gray-text);margin-bottom:0.75rem;">Key Takeaways</h2>
        <ul style="margin:0;padding-left:1.25rem;">
          {% for t in page.key_takeaways %}
          <li style="margin-bottom:0.35rem;font-size:0.9rem;line-height:1.5;">{{ t }}</li>
          {% endfor %}
        </ul>
      </aside>
      {% endif %}

      <!-- Body -->
      <div class="article-body" style="line-height:1.75;">
        {{ page.body_html | safe }}
      </div>

      <!-- FAQ accordion -->
      {% if faq %}
      <section style="margin-top:2.5rem;" aria-labelledby="faq-heading">
        <h2 id="faq-heading">Frequently Asked Questions</h2>
        <div class="faq-list">
          {% for item in faq %}
          <details class="faq-item" style="border-bottom:1px solid var(--sr-gray-light);padding:0.75rem 0;">
            <summary style="font-weight:600;cursor:pointer;font-size:0.95rem;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              {{ item.question }}
              <span style="font-size:1.2rem;color:var(--sr-blue);margin-left:0.5rem;flex-shrink:0;">+</span>
            </summary>
            <div style="padding:0.75rem 0 0.25rem;font-size:0.9rem;line-height:1.6;color:var(--sr-dark-text);">
              {{ item.answer }}
            </div>
          </details>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      <!-- Spoke links (for pillar pages) -->
      {% if spokes %}
      <section style="margin-top:2.5rem;">
        <h2>In This Guide</h2>
        <div class="card-grid" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr));">
          {% for s in spokes %}
          <a href="{{ s.url }}" class="cluster-card" style="text-decoration:none;color:inherit;">
            <h3 style="font-size:0.95rem;color:var(--sr-blue);">{{ s.label }}</h3>
            {% if s.description %}<p>{{ s.description }}</p>{% endif %}
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      <!-- Last updated -->
      {% if page.updated_at %}
      <p style="font-size:0.78rem;color:var(--sr-gray-text);margin-top:2rem;">
        Last updated: {{ page.updated_at.strftime('%B %d, %Y') }}
      </p>
      {% endif %}

      <!-- Disclaimer -->
      <div class="page-disclaimer">
        <strong>Disclaimer:</strong> Rank and Pay provides general information only and is not a
        law firm. Nothing on this site constitutes legal, financial, or benefits advice. Always
        verify information with the VA or an accredited claims agent.
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="layout-sidebar">
      {% if toc %}
      <div class="toc-aside">
        <h3>On This Page</h3>
        <ol>
          {% for item in toc %}
          <li><a href="#{{ item.anchor }}">{{ item.label }}</a></li>
          {% endfor %}
        </ol>
      </div>
      {% endif %}

      {{ cluster_nav(cluster_ctx) }}

      <!-- Email capture widget -->
      <div style="background:var(--sr-blue);color:var(--white);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-top:1.5rem;">
        <h3 style="color:var(--white);font-size:0.95rem;margin-bottom:0.4rem;">Get free daily updates</h3>
        <p style="font-size:0.82rem;opacity:0.85;margin-bottom:0.75rem;line-height:1.5;">VA policy changes and benefit rate updates — delivered to your inbox.</p>
        <form action="/api/subscribe" method="POST" style="display:flex;flex-direction:column;gap:0.5rem;">
          <input type="email" name="email" placeholder="you@example.com" required
                 style="padding:0.5rem 0.75rem;border-radius:var(--radius);border:none;font-size:0.875rem;">
          <button type="submit" class="btn btn--primary" style="background:var(--sr-red);border-color:var(--sr-red);">Subscribe</button>
        </form>
      </div>
    </aside>

  </div>
</main>

<script>
  document.querySelectorAll('.faq-item summary').forEach(function(s) {
    s.addEventListener('click', function() {
      var plus = s.querySelector('span');
      if (plus) plus.textContent = s.parentElement.open ? '+' : '−';
    });
  });
</script>
{% endblock %}
