// =========================================================
// Helper functions
// =========================================================
function getBasePay(grade, yos) {
  var row = PAY_TABLE_2025[grade];
  if (!row) return 0;
  var idx = 0;
  for (var i = 0; i < YOS_BRACKETS.length; i++) {
    if (yos >= YOS_BRACKETS[i]) idx = i;
  }
  return row[idx];
}

function fmt(n) {
  return '$' + n.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
}

function getSelectedSystem() {
  var radios = document.querySelectorAll('input[name="ret-system"]');
  for (var i = 0; i < radios.length; i++) {
    if (radios[i].checked) return radios[i].value;
  }
  return 'high36';
}

// =========================================================
// Auto-fill high-3 pay when grade or YOS changes
// =========================================================
function updateHighPay() {
  var grade = document.getElementById('pay-grade').value;
  var yos = parseInt(document.getElementById('yos-input').value, 10) || 20;
  var basePay = getBasePay(grade, yos);
  var high3El = document.getElementById('high3-pay');
  if (!high3El.dataset.userEdited) {
    high3El.value = basePay || '';
  }
}

document.getElementById('pay-grade').addEventListener('change', updateHighPay);
document.getElementById('yos-input').addEventListener('input', updateHighPay);
document.getElementById('high3-pay').addEventListener('input', function() {
  this.dataset.userEdited = '1';
});

// =========================================================
// Toggle TSP withdrawal amount field
// =========================================================
function toggleTspFields() {
  var strategy = document.getElementById('tsp-strategy').value;
  var wrap = document.getElementById('tsp-amount-wrap');
  if (strategy === '4pct') {
    wrap.style.display = 'none';
  } else {
    wrap.style.display = 'block';
    var label = wrap.querySelector('label');
    if (strategy === 'monthly') {
      label.textContent = 'Monthly Withdrawal Amount';
    } else {
      label.textContent = 'Fixed Monthly Amount';
    }
  }
}

// =========================================================
// Main calculation
// =========================================================
function calculateTotalIncome() {
  var system = getSelectedSystem();
  var grade = document.getElementById('pay-grade').value;
  var yos = parseInt(document.getElementById('yos-input').value, 10) || 20;
  if (yos < 20) yos = 20;
  if (yos > 40) yos = 40;

  var basePay = getBasePay(grade, yos);
  var high3Pay = parseFloat(document.getElementById('high3-pay').value) || basePay;

  // 1. Retirement pay
  var retMultiplier, retMonthly;
  if (system === 'finalpay') {
    retMultiplier = 2.5 * yos;
    retMonthly = (retMultiplier / 100) * basePay;
  } else if (system === 'high36') {
    retMultiplier = 2.5 * yos;
    retMonthly = (retMultiplier / 100) * high3Pay;
  } else {
    // BRS
    retMultiplier = 2.0 * yos;
    retMonthly = (retMultiplier / 100) * high3Pay;
  }

  // 2. VA compensation
  var vaRating = parseInt(document.getElementById('va-rating').value, 10);
  var depStatus = document.getElementById('dep-status').value;
  var effectiveStatus = vaRating < 30 ? 'alone' : depStatus;
  var vaMonthly = VA_RATES[effectiveStatus][vaRating] || 0;

  // 3. TSP income
  var tspBalance = parseFloat(document.getElementById('tsp-balance').value) || 0;
  var tspStrategy = document.getElementById('tsp-strategy').value;
  var tspMonthly = 0;

  if (tspStrategy === '4pct') {
    tspMonthly = (tspBalance * 0.04) / 12;
  } else {
    tspMonthly = parseFloat(document.getElementById('tsp-monthly-amt').value) || 0;
  }

  // Total
  var totalMonthly = retMonthly + vaMonthly + tspMonthly;

  // Update summary cards
  document.getElementById('res-ret-monthly').textContent = fmt(retMonthly);
  document.getElementById('res-ret-annual').textContent = fmt(retMonthly * 12) + '/year';
  document.getElementById('res-va-monthly').textContent = fmt(vaMonthly);
  document.getElementById('res-va-annual').textContent = fmt(vaMonthly * 12) + '/year';
  document.getElementById('res-tsp-monthly').textContent = fmt(tspMonthly);
  document.getElementById('res-tsp-annual').textContent = fmt(tspMonthly * 12) + '/year';
  document.getElementById('res-total-monthly').textContent = fmt(totalMonthly);
  document.getElementById('res-total-annual').textContent = fmt(totalMonthly * 12) + '/year';

  // Update bar chart
  if (totalMonthly > 0) {
    var retPct = (retMonthly / totalMonthly * 100);
    var vaPct = (vaMonthly / totalMonthly * 100);
    var tspPct = (tspMonthly / totalMonthly * 100);

    document.getElementById('bar-ret').style.width = retPct + '%';
    document.getElementById('bar-va').style.width = vaPct + '%';
    document.getElementById('bar-tsp').style.width = tspPct + '%';

    document.getElementById('bar-ret-pct').textContent = '(' + retPct.toFixed(1) + '%)';
    document.getElementById('bar-va-pct').textContent = '(' + vaPct.toFixed(1) + '%)';
    document.getElementById('bar-tsp-pct').textContent = '(' + tspPct.toFixed(1) + '%)';
  } else {
    document.getElementById('bar-ret').style.width = '0%';
    document.getElementById('bar-va').style.width = '0%';
    document.getElementById('bar-tsp').style.width = '0%';
    document.getElementById('bar-ret-pct').textContent = '';
    document.getElementById('bar-va-pct').textContent = '';
    document.getElementById('bar-tsp-pct').textContent = '';
  }

  // Show results
  document.getElementById('results').style.display = 'block';
  document.getElementById('results').scrollIntoView({behavior: 'smooth', block: 'nearest'});
}

// Initialize
updateHighPay();
</script>
