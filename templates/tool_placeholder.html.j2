{% extends "_base.html.j2" %}
{% block title %}{{ seo.title }}{% endblock %}
{% block meta_description %}{{ seo.description }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endblock %}
{% block og_tags %}
<meta property="og:title" content="{{ seo.title | e }}">
<meta property="og:description" content="{{ seo.description | e }}">
<meta property="og:url" content="{{ seo.canonical }}">
<meta property="og:type" content="website">
{% endblock %}

{% block content %}
<section class="hero" style="padding:2.5rem 0 2rem;">
  <div class="container">
    <h1>{{ tool.title }}</h1>
    <p>{{ tool.description }}</p>
  </div>
</section>

<main class="container" style="max-width:680px;margin:2rem auto;padding:0 1.25rem;text-align:center;">

  <div style="background:var(--sr-gray-bg);border:1px solid var(--sr-gray-light);border-radius:var(--radius);padding:2.5rem 2rem;margin-bottom:2rem;">
    <span style="font-size:3rem;display:block;margin-bottom:1rem;">{{ tool.icon }}</span>
    <h2 style="font-size:1.2rem;margin-bottom:0.5rem;">{{ tool.title }} — Coming Soon</h2>
    <p style="color:var(--sr-gray-text);margin-bottom:1.5rem;line-height:1.6;">
      We're building this tool now. Enter your email and we'll notify you the moment it goes live — free, no spam.
    </p>

    <form action="/api/email-capture" method="POST" id="waitlist-form" style="max-width:380px;margin:0 auto;">
      <input type="hidden" name="tool_slug" value="{{ tool.slug }}">
      <input type="hidden" name="source" value="tool_waitlist">
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;justify-content:center;">
        <input type="email" name="email" placeholder="your@email.com" required
               style="flex:1;min-width:200px;padding:0.6rem 0.9rem;border:1px solid var(--sr-gray-light);border-radius:var(--radius);font-size:0.9rem;">
        <button type="submit" class="btn btn--primary">Notify me</button>
      </div>
      <!-- Honeypot -->
      <input type="text" name="website" style="display:none !important;" tabindex="-1" autocomplete="off">
    </form>

    <p id="waitlist-success" style="display:none;color:#155724;font-weight:600;margin-top:1rem;">
      You're on the list! We'll email you when {{ tool.title }} is live.
    </p>
  </div>

  <!-- Why this tool matters -->
  {% if tool.why_matters %}
  <div style="text-align:left;margin-bottom:2rem;">
    <h3 style="font-size:1rem;margin-bottom:0.5rem;">Why this tool matters</h3>
    <p style="color:var(--sr-gray-text);line-height:1.6;">{{ tool.why_matters }}</p>
  </div>
  {% endif %}

  <!-- Related tools -->
  {% if related_tools %}
  <div style="text-align:left;margin-bottom:2rem;">
    <h3 style="font-size:1rem;margin-bottom:0.75rem;">Other tools</h3>
    <ul style="list-style:none;padding:0;margin:0;">
      {% for rt in related_tools %}
      <li style="margin-bottom:0.4rem;">
        <a href="/tools/{{ rt.slug }}/" style="color:var(--sr-blue);">{{ rt.title }}</a>
        <span class="status-pill" style="margin-left:0.4rem;">{{ 'Live' if rt.live else 'Soon' }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <p style="font-size:0.875rem;"><a href="/tools/">&larr; All tools</a></p>

</main>

<script>
  (function () {
    var form = document.getElementById('waitlist-form');
    var success = document.getElementById('waitlist-success');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var honeypot = form.querySelector('[name="website"]');
      if (honeypot && honeypot.value) return;
      var data = new FormData(form);
      fetch(form.action, { method: 'POST', body: data })
        .then(function () {
          form.style.display = 'none';
          if (success) success.style.display = 'block';
        })
        .catch(function () {
          form.style.display = 'none';
          if (success) success.style.display = 'block';
        });
    });
  })();
</script>
{% endblock %}
