{% extends "_base.html.j2" %}
{% block title %}{{ seo.title }}{% endblock %}
{% block meta_description %}{{ seo.description }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endblock %}
{% block og_tags %}
<meta property="og:title" content="{{ seo.title | e }}">
<meta property="og:description" content="{{ seo.description | e }}">
<meta property="og:url" content="{{ seo.canonical }}">
<meta property="og:type" content="article">
<meta property="og:image" content="{{ seo.og_image }}">
<meta property="article:published_time" content="{{ seo.published_iso }}">
{% if seo.modified_iso %}<meta property="article:modified_time" content="{{ seo.modified_iso }}">{% endif %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo.title | e }}">
<meta name="twitter:description" content="{{ seo.description | e }}">
<meta name="twitter:image" content="{{ seo.og_image }}">
{% endblock %}
{% block jsonld %}<script type="application/ld+json">{{ jsonld | tojson }}</script>{% endblock %}

{% block content %}
<main>
  <article class="container" style="max-width:760px;margin:2rem auto;padding:0 1.25rem;">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" style="font-size:0.82rem;margin-bottom:1.25rem;color:var(--sr-gray-text);">
      <a href="/">Home</a> &rsaquo;
      <a href="/briefing/">Briefings</a> &rsaquo;
      <span>{{ post.title | truncate(50) }}</span>
    </nav>

    <!-- Header -->
    <header style="margin-bottom:1.5rem;">
      <div class="post-list-meta" style="margin-bottom:0.6rem;">
        <span class="post-list-date">{{ post.published_date.strftime('%B %d, %Y') }}</span>
        {% if post.primary_sector %}
        <span class="tag">{{ post.primary_sector | replace('_', ' ') | title }}</span>
        {% endif %}
      </div>
      <h1 style="font-size:clamp(1.5rem,3.5vw,2.1rem);line-height:1.25;">{{ post.title }}</h1>
      {% if post.summary %}
      <p style="font-size:1.05rem;color:var(--sr-gray-text);margin-top:0.6rem;line-height:1.6;">{{ post.summary }}</p>
      {% endif %}
    </header>

    <!-- Share bar -->
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.75rem;align-items:center;">
      <span style="font-size:0.8rem;color:var(--sr-gray-text);font-weight:600;">Share:</span>
      <a class="btn btn--secondary" style="font-size:0.8rem;padding:0.3rem 0.8rem;"
         href="https://twitter.com/intent/tweet?url={{ seo.canonical | urlencode }}&text={{ post.title | urlencode }}"
         target="_blank" rel="noopener">Twitter/X</a>
      <a class="btn btn--secondary" style="font-size:0.8rem;padding:0.3rem 0.8rem;"
         href="https://www.facebook.com/sharer/sharer.php?u={{ seo.canonical | urlencode }}"
         target="_blank" rel="noopener">Facebook</a>
      <button class="btn btn--secondary share-btn--copy" style="font-size:0.8rem;padding:0.3rem 0.8rem;"
              data-url="{{ seo.canonical }}">Copy link</button>
    </div>

    <!-- Key takeaways -->
    {% if takeaways %}
    <aside style="background:var(--sr-gray-bg);border:1px solid var(--sr-gray-light);border-left:4px solid var(--sr-blue);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:1.75rem;">
      <h2 style="font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--sr-gray-text);margin-bottom:0.75rem;">Key Takeaways</h2>
      <ul style="margin:0;padding-left:1.25rem;">
        {% for t in takeaways %}
        <li style="margin-bottom:0.35rem;font-size:0.9rem;line-height:1.5;">
          {{ t.answer if t is mapping else t }}
        </li>
        {% endfor %}
      </ul>
    </aside>
    {% endif %}

    <!-- Body -->
    <div class="article-body" style="line-height:1.75;font-size:1rem;">
      {{ post.content | safe }}
    </div>

    <!-- Source attribution -->
    {% if post.source_url %}
    <div class="source-attribution" style="margin-top:2rem;">
      <strong>Source:</strong>
      <a href="{{ post.source_url }}" target="_blank" rel="noopener nofollow">{{ post.source_name or post.source_url }}</a>
    </div>
    {% endif %}

    <!-- Related briefings -->
    {% if related %}
    <section style="margin-top:2.5rem;border-top:1px solid var(--sr-gray-light);padding-top:1.5rem;">
      <h2 style="font-size:1.05rem;margin-bottom:1rem;">Related News</h2>
      <div class="card-grid">
        {% for rp in related %}
        <article class="briefing-card">
          <div class="briefing-card-meta">
            <span class="briefing-card-date">{{ rp.published_date.strftime('%b %d, %Y') }}</span>
          </div>
          <h3><a href="/briefing/{{ rp.slug }}/">{{ rp.title }}</a></h3>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <!-- Back nav -->
    <p style="margin-top:2rem;font-size:0.875rem;">
      <a href="/briefing/">&larr; All briefings</a>
    </p>

  </article>
</main>
{% endblock %}
