{% macro cluster_nav(ctx) %}
{% if ctx and ctx.hub_label %}
<nav class="cluster-nav" aria-label="Related topics">
  <h3 class="cluster-nav-heading">In this guide</h3>
  <ul class="cluster-nav-list">
    <li>
      <a href="{{ ctx.hub_url }}"{% if ctx.hub_active %} class="cluster-nav-active" aria-current="page"{% endif %}>
        {{ ctx.hub_label }}
      </a>
    </li>
    {% for s in ctx.siblings %}
    <li>
      <a href="{{ s.url }}"{% if s.active %} class="cluster-nav-active" aria-current="page"{% endif %}>
        {{ s.label }}
      </a>
    </li>
    {% endfor %}
  </ul>
</nav>
{% endif %}
{% endmacro %}

<style>
  .cluster-nav {
    background: var(--sr-gray-bg);
    border: 1px solid var(--sr-gray-light);
    border-left: 4px solid var(--sr-blue);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.1rem 1.25rem;
    margin: 1.5rem 0;
  }

  .cluster-nav-heading {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sr-gray-text);
    margin-bottom: 0.65rem;
  }

  .cluster-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cluster-nav-list li {
    margin-bottom: 0;
    border-bottom: 1px solid var(--sr-gray-light);
  }

  .cluster-nav-list li:last-child {
    border-bottom: none;
  }

  .cluster-nav-list a {
    display: block;
    padding: 0.45rem 0.25rem;
    color: var(--sr-blue);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s, padding-left 0.15s;
  }

  .cluster-nav-list a:hover {
    color: var(--sr-red);
    padding-left: 0.4rem;
  }

  .cluster-nav-list a.cluster-nav-active {
    font-weight: 700;
    color: var(--sr-dark-text);
    padding-left: 0.4rem;
    border-left: 2px solid var(--sr-red);
    margin-left: -0.25rem;
  }
</style>
