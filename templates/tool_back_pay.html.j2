    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem;margin-bottom:1.5rem;">

      <div>
        <label for="effective-month" style="display:block;font-size:0.9rem;font-weight:600;color:var(--sr-gray-text);margin-bottom:0.35rem;">Effective Date (Month/Year)</label>
