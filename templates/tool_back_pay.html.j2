<section style="background:var(--sr-blue);color:#fff;padding:2.5rem 0 2rem;">
  <div class="container" style="max-width:1040px;">
    <h1 style="color:#fff;font-size:clamp(1.5rem,3vw,2.1rem);margin-bottom:0.5rem;">VA Disability Back Pay Calculator 2026</h1>
    <p style="opacity:0.9;max-width:640px;margin:0;">Use this free <strong>VA back pay calculator</strong> to estimate how much retroactive <strong>VA disability back pay</strong> you may receive based on your effective date, decision date, and disability rating.</p>
  </div>
</section>

<main class="container" style="max-width:1040px;margin:2rem auto;padding:0 1.25rem;">

  <!-- Calculator Card -->
