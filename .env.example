# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/vet_tools

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_PREMIUM_MODEL=gpt-4o

# ── Site identity ─────────────────────────────────────────────────────────────
SITE_URL=https://yourdomain.com
SITE_NAME=VA Claims Workspace

# ── Newsletter ────────────────────────────────────────────────────────────────
NEWSLETTER_PROVIDER=buttondown
NEWSLETTER_FROM_EMAIL=briefing@yourdomain.com
NEWSLETTER_API_KEY=
BUTTONDOWN_API_KEY=
RESEND_API_KEY=

# ── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_REPORT_BUCKET=reports
SUPABASE_REPORT_OBJECT_KEY=va-report.html

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=

# ── Distribution: Google Indexing API ────────────────────────────────────────
GOOGLE_INDEXING_SA_JSON=

# ── Distribution: IndexNow ────────────────────────────────────────────────────
INDEXNOW_KEY=

# ── Distribution: Internet Archive ───────────────────────────────────────────
INTERNET_ARCHIVE_ACCESS_KEY=
INTERNET_ARCHIVE_SECRET_KEY=

# ── Distribution: Zenodo ─────────────────────────────────────────────────────
ZENODO_ACCESS_TOKEN=

# ── Distribution: OSF Preprints ──────────────────────────────────────────────
OSF_ACCESS_TOKEN=
OSF_PROJECT_NODE_ID=

# ── Analytics ─────────────────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=

# ── Press Radar ───────────────────────────────────────────────────────────────
PRESS_RADAR_RECIPIENT_EMAIL=
PRESS_RADAR_FROM_EMAIL=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Google Reporting (GA4 + Search Console) ──────────────────────────────────
GOOGLE_REPORTING_SA_JSON=
GOOGLE_REPORTING_GA4_PROPERTY_ID=
GOOGLE_REPORTING_GSC_SITE_URL=
