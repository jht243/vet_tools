# ── Database (Supabase Postgres — session pooler, IPv4-friendly) ────
# IMPORTANT: must be the *session pooler* (port 5432, host
# aws-1-us-east-1.pooler.supabase.com) — the transaction pooler does
# not work with SQLAlchemy connection pooling.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ── Storage / logs ─────────────────────────────────────────────────
STORAGE_DIR=./storage
LOG_LEVEL=INFO

# Public site (canonical domain for SEO, emails, intake links). On Render,
# set this to your custom domain — *.onrender.com is overridden for customer-facing
# visa emails even if SITE_URL was left as the default Render hostname.
SITE_URL=https://caracasresearch.com

# ── Scraper settings ───────────────────────────────────────────────
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY_SECONDS=60
SCRAPER_LOOKBACK_DAYS=30

# How many days back the report includes. 120 covers Jan 1 → mid-April
# of the same year. Bump for a longer rolling window.
REPORT_LOOKBACK_DAYS=120

# ── Tesseract (OCR for gazette PDFs) ──────────────────────────────
TESSERACT_CMD=/usr/local/bin/tesseract
TESSERACT_LANG=spa

# ── OpenAI (REQUIRED — powers the LLM investor analysis) ─────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANALYSIS_MIN_RELEVANCE=5

# Hard cap on LLM calls per pipeline run. At gpt-4o pricing each call
# is ~$0.006, so 200 calls/run = ~$1.20/run. With the cron firing
# twice a day that's ~$2.40/day worst case. Bump this if you have
# more daily budget; lower it if you're seeing higher spend.
LLM_CALL_BUDGET_PER_RUN=200

# Premium model — used ONLY for evergreen, high-traffic landing pages
# (pillar /invest-in-venezuela, /sectors/{name}, evergreen explainers).
# Daily news analysis and blog posts continue to use OPENAI_MODEL above
# because they run hundreds of times. The premium model is invoked only
# when an evergreen page is regenerated, which is roughly weekly.
# Reasonable choices: gpt-4.5-preview, gpt-4-turbo, claude-via-router.
OPENAI_PREMIUM_MODEL=gpt-5.2
LLM_PREMIUM_INPUT_PRICE_PER_MTOK=5.00
LLM_PREMIUM_OUTPUT_PRICE_PER_MTOK=15.00

# ── Buttondown (subscriber signup from the website) ──
# Get a key at https://buttondown.com/settings/programming
BUTTONDOWN_API_KEY=

# ── Newsletter (optional — set to "buttondown" or "sendgrid") ────
# While set to "console", emails are printed to logs only.
NEWSLETTER_PROVIDER=buttondown
NEWSLETTER_FROM_EMAIL=briefing@venezuelanbusiness.net
NEWSLETTER_API_KEY=
SUBSCRIBER_LIST_PATH=subscribers.json

# ── Stripe visa-service checkout notifications ──
# In Stripe Dashboard, create a webhook endpoint for:
#   https://caracasresearch.com/webhooks/stripe
# listening to checkout.session.completed, then paste the endpoint signing
# secret below. The app sends an email when a paid visa-service order lands.
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_VISA_PAYMENT_LINK_ID=plink_1TS1T2GWYDLBQAio3Z6tN9N2
VISA_ORDER_NOTIFICATION_EMAIL=you@example.com
VISA_ORDER_EMAIL_PROVIDER=resend
VISA_ORDER_FROM_EMAIL=hello@intake.layer3labs.io
VISA_REPLY_TO_EMAIL=jonathan@layer3labs.io
VISA_ADMIN_KEY=change-me-to-a-random-string
VISA_ADMIN_PASSWORD=
# Shared Cancillería portal password shown only in /admin (override if it changes)
VISA_PORTAL_SHARED_PASSWORD=VisaVene34!
RESEND_API_KEY=

# ── Backlink outreach MVP ──────────────────────────────────────────
# Semrush API key is required for competitor backlinks/referring domains.
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
RESEND_OUTREACH_FROM="Jonathan <jonathan@caracasresearch.com>"
OUTREACH_MIN_SCORE=65
OUTREACH_BATCH_SIZE=50
OUTREACH_DELAY_SECONDS=30

# ── Supabase Storage ─────────────────────────────────────────────
# The cron uploads report.html here; the web service reads it.
# Bucket must be public and allow text/html MIME types.
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key — REQUIRED for the cron (uploads). Web does NOT need it.
SUPABASE_SERVICE_KEY=
SUPABASE_REPORT_BUCKET=reports

# ── Distribution: IndexNow (Bing, Yandex, Seznam, Naver, Mojeek) ─
# Generate at https://www.bing.com/indexnow/getstarted (one-click).
# Not a secret — the protocol publishes it at /{key}.txt to prove
# domain ownership, and includes it in every API call. Without this,
# the IndexNow distribution channel is silently skipped.
INDEXNOW_KEY=

# ── Distribution: Google Indexing API ────────────────────────────
# Service-account JSON for the Google Indexing API. Paste the entire
# JSON file contents (including {} and the embedded \n in private_key)
# as the value of this single env var. The service account must be
# added as an OWNER of the verified Search Console property for
# caracasresearch.com (Editor permission is not enough). Leave blank
# to disable Google Indexing pings; the rest of the pipeline runs as
# normal.
GOOGLE_INDEXING_SA_JSON=
# Alternate: path to the JSON file on disk (used by Render "secret
# files" mounts). Only consulted when GOOGLE_INDEXING_SA_JSON is empty.
GOOGLE_INDEXING_SA_FILE=

# ── Nightly Sitemap Sync (scripts/sync_sitemap.py) ───────────────
# Fine-grained GitHub PAT with Contents: Read & Write on the repo.
# Needed so the nightly cron on Render can commit + push sitemap
# fixes back to the repo. Without this, the script still audits
# and detects missing routes / dead links — it just can't push.
GITHUB_TOKEN=
GITHUB_REPO=jht243/ven_biz_network

# ── Distribution: Internet Archive (archive.org) ──────────────────
# S3-like access keys generated at https://archive.org/account/s3.php
# (free; just need an archive.org account). Used to permanently
# deposit each daily Investor Tearsheet PDF as a public IA item,
# which gets indexed by Google and Google Scholar over time.
INTERNET_ARCHIVE_ACCESS_KEY=
INTERNET_ARCHIVE_SECRET_KEY=
INTERNET_ARCHIVE_COLLECTION=opensource
INTERNET_ARCHIVE_MAX_PER_RUN=5

# ── Distribution: Zenodo (CERN open repository) ──────────────────
# Zenodo gives every record a permanent DOI and is indexed by Google
# Search + Google Dataset Search + OpenAIRE. Generate a token at
# https://zenodo.org/account/settings/applications/tokens/new/ with
# scopes `deposit:write` and `deposit:actions`. Leave blank to disable.
ZENODO_ACCESS_TOKEN=
# Set to "1" or "true" to publish to the sandbox host (sandbox.zenodo.org)
# instead of production. Sandbox tokens are issued separately at
# https://sandbox.zenodo.org/account/settings/applications/tokens/new/
ZENODO_USE_SANDBOX=
# Optional Zenodo "community" slug to request inclusion in. Leave blank
# unless you've created/joined a community for these tearsheets.
ZENODO_COMMUNITY=
ZENODO_MAX_PER_RUN=3

# ── Distribution: OSF Preprints (Open Science Framework) ─────────
# OSF Preprints IS indexed by Google Scholar (the main reason to use it).
# 1. Create a Personal Access Token: https://osf.io/settings/tokens/
#    with scope `osf.full_write`.
# 2. Manually create one OSF "project" at osf.io to act as the parent
#    container for all daily tearsheets, then paste its 5-char GUID below.
# 3. Pick a preprint provider: "osf" (generic), "socarxiv" (social
#    sciences), "metaarxiv" (metascience). "osf" is the safest default.
OSF_ACCESS_TOKEN=
OSF_PROJECT_NODE_ID=
OSF_PREPRINT_PROVIDER=osf
# BePress taxonomy ID for the preprint subject. Default is Economics;
# only change if you switch providers (each provider has its own
# subject whitelist).
OSF_SUBJECT_ID=584240da54be81056cecaab4
OSF_LICENSE_NAME=CC-By Attribution 4.0 International
OSF_MAX_PER_RUN=3

# ── Distribution: Bluesky (atproto) ──────────────────────────────
# Account handle (e.g. caracasresearch.bsky.social) and an APP PASSWORD
# (Bluesky → Settings → Privacy and Security → App Passwords). NEVER
# put the real account password here. Leave either blank to disable
# Bluesky posting. Lookback days controls how far back to consider
# briefings as "new"; max-per-run is the safety cap per cron run.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
BLUESKY_LOOKBACK_DAYS=2
BLUESKY_MAX_PER_RUN=5

# ── Server ────────────────────────────────────────────────────────
SERVER_PORT=8080
